<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  @{
    var brandName = ViewData["BrandName"] as string;
    if (string.IsNullOrWhiteSpace(brandName))
    {
      brandName = "RestoBill";
    }
  }
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>@ViewData["Title"] | @brandName</title>
  <meta name="app-brand-default" content="@brandName"/>
  <meta name="theme-color" content="#09090b"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="~/lib/font-awesome/6.5.0/css/all.min.css" asp-append-version="true"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body class="auth-layout-body">
<div class="global-float-layer" aria-hidden="true">
  <div class="global-float gfloat-chili"><i class="fas fa-pepper-hot"></i></div>
  <div class="global-float gfloat-coffee"><i class="fas fa-mug-hot"></i></div>
  <div class="global-float gfloat-dish"><i class="fas fa-bowl-food"></i></div>
  <div class="global-float gfloat-bread"><i class="fas fa-bread-slice"></i></div>
  <div class="global-float gfloat-burger"><i class="fas fa-burger"></i></div>
  <div class="global-float gfloat-pizza"><i class="fas fa-pizza-slice"></i></div>
  <div class="global-float gfloat-ice"><i class="fas fa-ice-cream"></i></div>
  <div class="global-float gfloat-fish"><i class="fas fa-fish"></i></div>
  <div class="global-float gfloat-leaf"><i class="fas fa-leaf"></i></div>
  <div class="global-float gfloat-star"><i class="fas fa-star"></i></div>
  <div class="global-float gfloat-cookie"><i class="fas fa-cookie-bite"></i></div>
  <div class="global-float gfloat-drumstick"><i class="fas fa-drumstick-bite"></i></div>
  <div class="global-float gfloat-apple"><i class="fas fa-apple-whole"></i></div>
  <div class="global-float gfloat-cheese"><i class="fas fa-cheese"></i></div>
  <div class="global-float gfloat-shrimp"><i class="fas fa-shrimp"></i></div>
  <div class="global-float gfloat-bolt"><i class="fas fa-bolt"></i></div>
</div>
@RenderBody()
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
