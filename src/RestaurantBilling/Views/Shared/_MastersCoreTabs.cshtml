@{
    var path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
    var isCategories = path.StartsWith("/master/categories") || path.StartsWith("/masters/categories");
    var isItems = path.StartsWith("/master/items") || path.StartsWith("/masters/items");
    var isUnits = path.StartsWith("/master/units") || path.StartsWith("/masters/units");
    var isTables = path.StartsWith("/master/table") || path.StartsWith("/masters/table") ||
    path.StartsWith("/master/tables") || path.StartsWith("/masters/tables");
}

<div class="app-module-header">
    <h1 class="h3 mb-1">Masters</h1>
    <p class="app-muted mb-0">Manage core menu and inventory setup.</p>
</div>

<div class="card p-2 mb-3">
    <div class="card-body-custom py-2">
        <ul class="nav app-switch-tabs mb-0" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link @(isCategories ? "active" : "")" href="/master/categories" role="tab">Categories</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link @(isItems ? "active" : "")" href="/master/items" role="tab">Menu Items</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link @(isUnits ? "active" : "")" href="/master/units" role="tab">Units</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link @(isTables ? "active" : "")" href="/master/table" role="tab">Tables</a>
            </li>
        </ul>
    </div>
</div>
