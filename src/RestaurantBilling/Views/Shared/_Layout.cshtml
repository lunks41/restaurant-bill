@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Data.Persistence
@inject SignInManager<IdentityUser<int>> SignInManager
@inject UserManager<IdentityUser<int>> UserManager
@inject AppDbContext Db
@{
  var path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
  bool IsActive(string prefix) => path.StartsWith(prefix);
  string LinkClass(string prefix) => IsActive(prefix) ? "nav-link-item active" : "nav-link-item";
  string TopbarLinkClass(string prefix) => IsActive(prefix) ? "topbar-quick-link active" : "topbar-quick-link";
  var configuredBrand = await Db.RestaurantSettings
    .AsNoTracking()
    .Where(x => x.SettingKey == "RestaurantName")
    .Select(x => x.SettingValue)
    .FirstOrDefaultAsync();
  var brandName = string.IsNullOrWhiteSpace(configuredBrand) ? "RestoBill" : configuredBrand.Trim();
}
<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <script>(function(){try{if(localStorage.getItem('sidebarCollapsed')==='true'&&window.innerWidth>768)document.documentElement.setAttribute('data-sidebar-init','collapsed');}catch(e){}}());</script>
  <title>@ViewData["Title"] | @brandName</title>
  <meta name="app-brand-default" content="@brandName" />
  <meta name="theme-color" content="#09090b" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/lib/font-awesome/6.5.0/css/all.min.css" asp-append-version="true" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
  <link href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" rel="stylesheet" />
  @if (ViewBag.UseSelect2 == true)
  {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css"
      rel="stylesheet" />
  }
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  @await RenderSectionAsync("Styles", required: false)
</head>

<body>
  <div class="global-float-layer" aria-hidden="true">
    <div class="global-float gfloat-chili"><i class="fas fa-pepper-hot"></i></div>
    <div class="global-float gfloat-coffee"><i class="fas fa-mug-hot"></i></div>
    <div class="global-float gfloat-dish"><i class="fas fa-bowl-food"></i></div>
    <div class="global-float gfloat-bread"><i class="fas fa-bread-slice"></i></div>
    <div class="global-float gfloat-burger"><i class="fas fa-burger"></i></div>
    <div class="global-float gfloat-pizza"><i class="fas fa-pizza-slice"></i></div>
    <div class="global-float gfloat-ice"><i class="fas fa-ice-cream"></i></div>
    <div class="global-float gfloat-fish"><i class="fas fa-fish"></i></div>
    <div class="global-float gfloat-leaf"><i class="fas fa-leaf"></i></div>
    <div class="global-float gfloat-star"><i class="fas fa-star"></i></div>
    <div class="global-float gfloat-cookie"><i class="fas fa-cookie-bite"></i></div>
    <div class="global-float gfloat-drumstick"><i class="fas fa-drumstick-bite"></i></div>
    <div class="global-float gfloat-apple"><i class="fas fa-apple-whole"></i></div>
    <div class="global-float gfloat-cheese"><i class="fas fa-cheese"></i></div>
    <div class="global-float gfloat-shrimp"><i class="fas fa-shrimp"></i></div>
    <div class="global-float gfloat-bolt"><i class="fas fa-bolt"></i></div>
  </div>
  @if (SignInManager.IsSignedIn(User))
  {
    <div class="app-shell">
      <aside class="sidebar" id="appSidebar">
        <div class="sidebar-logo">
          <div class="logo-icon" id="brandLogoIcon">
            <img id="brandLogoImage" alt="Restaurant logo"
              style="display:none; width:100%; height:100%; object-fit:cover; border-radius:10px;" />
            <i class="fas fa-utensils" id="brandLogoFallback"></i>
          </div>
          <a href="/dashbord" class="logo-text" id="brandNameText" style="text-decoration:none;">@brandName</a>
        </div>
        <nav class="sidebar-nav">
          <div class="nav-group">
            <div class="nav-group-label">Operations</div>
            <a class="@LinkClass("/floor")" href="/floor"><i class="nav-icon fas fa-border-all"></i><span
                class="nav-label">KOT (Dining)</span></a>
            <a class="@LinkClass("/takeaway")" href="/takeaway"><i class="nav-icon fas fa-bag-shopping"></i><span
                class="nav-label">Takeaway</span></a>
            <a class="@LinkClass("/kot")" href="/kot" target="_blank" rel="noopener"><i
                class="nav-icon fas fa-fire-burner"></i><span class="nav-label">Kitchen View</span></a>
            <a class="@LinkClass("/bills")" href="/bills"><i class="nav-icon fas fa-clock-rotate-left"></i><span
                class="nav-label">Orders</span></a>
          </div>
          <div class="nav-group">
            <div class="nav-group-label">Masters</div>
            <a class="@LinkClass("/master/items")" href="/master/items"><i class="nav-icon fas fa-layer-group"></i><span
                class="nav-label">Masters</span></a>
            <a class="@LinkClass("/inventory")" href="/inventory"><i class="nav-icon fas fa-boxes-stacked"></i><span
                class="nav-label">Inventory</span></a>
            <a class="@LinkClass("/admin/users")" href="/admin/users"><i class="nav-icon fas fa-users"></i><span
                class="nav-label">Users</span></a>
            <a class="@LinkClass("/settings")" href="/settings"><i class="nav-icon fas fa-store"></i><span
                class="nav-label">Restaurant Info</span></a>
          </div>
          <div class="nav-group">
            <div class="nav-group-label">Analytics & Reports</div>
            <a class="@LinkClass("/dashbord")" href="/dashbord"><i class="nav-icon fas fa-table-cells-large"></i><span
                class="nav-label">Dashboard</span></a>
            <a class="@LinkClass("/reports/dailysales")" href="/reports/dailysales"><i
                class="nav-icon fas fa-calendar-day"></i><span class="nav-label">Daily Sales</span></a>
            <a class="@LinkClass("/reports/billwise")" href="/reports/billwise"><i
                class="nav-icon fas fa-file-invoice"></i><span class="nav-label">Bill Wise</span></a>
            @* <a class="@LinkClass("/reports/itemwise")" href="/reports/itemwise"><i
                class="nav-icon fas fa-bowl-food"></i><span class="nav-label">Item Wise</span></a>
            <a class="@LinkClass("/reports/paymentmode")" href="/reports/paymentmode"><i
                class="nav-icon fas fa-money-check-dollar"></i><span class="nav-label">Payment Mode</span></a> *@
            <a class="@LinkClass("/reports/dayclosereports")" href="/reports/dayclosereports"><i
                class="nav-icon fas fa-calendar-check"></i><span class="nav-label">Day Close Reports</span></a>
          </div>
        </nav>
       
      </aside>

      <div class="main-wrapper">
        <header class="topbar">
          <button class="topbar-toggle" id="sidebarToggle" title="Toggle sidebar"><i class="fas fa-bars"></i></button>
          <span class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
          <nav class="topbar-quick-nav" aria-label="Quick navigation">
            <a class="@TopbarLinkClass("/floor")" href="/floor"><i class="fas fa-border-all"></i><span>KOT
              </span></a>
            <a class="@TopbarLinkClass("/takeaway")" href="/takeaway"><i
                class="fas fa-bag-shopping"></i><span>Takeaway</span></a>
          </nav>
          <div class="topbar-spacer"></div>
          <div class="topbar-clock" id="liveClock"></div>
          <button class="topbar-help-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#processGuidePanel"
            aria-controls="processGuidePanel" title="Open process guide">
            <i class="fas fa-circle-question"></i>
          </button>
          <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme"><i id="themeIcon"
              class="fas fa-moon"></i></button>
          <div class="dropdown topbar-user-menu">
            <button class="topbar-user" id="userDropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <div class="avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")</div>
              <span class="uname d-none d-md-inline">@User.Identity?.Name</span>
              <i class="fas fa-chevron-down" style="font-size:10px;opacity:.75;"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
              <li><span class="dropdown-item-text text-muted small">@User.Identity?.Name</span></li>
              <li><hr class="dropdown-divider" /></li>
              <li>
                <a class="dropdown-item" href="/settings">
                  <i class="fas fa-store me-2"></i>Restaurant Info
                </a>
              </li>
              <li>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="dropdown-item text-danger">
                    <i class="fas fa-right-from-bracket me-2"></i>Logout
                  </button>
                </form>
              </li>
            </ul>
          </div>
        </header>
        <main class="main-content">
          @if (TempData["Success"] != null)
          {
            <div class="alert-custom success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
          }
          @if (TempData["Error"] != null)
          {
            <div class="alert-custom error"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
          }
          @RenderBody()
        </main>
      </div>
    </div>
  }
  else
  {
    <div class="container py-4">@RenderBody()</div>
  }

  @{
    var toastMessage = TempData["ToastMessage"] as string;
    var toastType = TempData["ToastType"] as string ?? "info";
    var toastClass = toastType switch
    {
      "success" => "text-bg-success",
      "danger" => "text-bg-danger",
      "warning" => "text-bg-warning",
      _ => "text-bg-primary"
    };
  }
  @if (!string.IsNullOrWhiteSpace(toastMessage))
  {
    <div class="toast-container position-fixed top-0 end-0 p-3">
      <div id="app-toast" class="toast @toastClass border-0" role="alert" aria-live="assertive" aria-atomic="true"
        data-bs-delay="3500">
        <div class="d-flex">
          <div class="toast-body">@toastMessage</div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
            aria-label="Close"></button>
        </div>
      </div>
    </div>
  }

  <div class="modal fade" id="globalConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="globalConfirmTitle">Please Confirm</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="globalConfirmMessage">
          Are you sure?
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" id="globalConfirmYes">Delete</button>
        </div>
      </div>
    </div>
  </div>

  <div class="offcanvas offcanvas-end process-guide-panel" tabindex="-1" id="processGuidePanel"
    aria-labelledby="processGuideLabel">
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="processGuideLabel"><i class="fas fa-circle-info me-2"></i>Quick Process Guide</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
      <div class="process-guide-intro">
        Read these cards once to understand the full flow from order to billing and reports.
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-border-all"></i> KOT (Dining)</div>
        <p>Open tables from <strong>KOT (Dining)</strong>, select items, then click <strong>Hold</strong> to save a draft.</p>
        <p>Use this screen for dine-in table orders and quick table switching during rush hours.</p>
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-bag-shopping"></i> Takeaway</div>
        <p>Create takeaway orders without table mapping, hold drafts, and settle directly at counter.</p>
        <p>Best for parcel/self-pickup flow where table tracking is not required.</p>
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-fire-burner"></i> Kitchen View / KOT List</div>
        <p>Send order to kitchen using <strong>KOT</strong> from POS. Kitchen team tracks pending and preparing tickets here.</p>
        <p>Mark progress in sequence so serving and billing stay synchronized.</p>
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-clock-rotate-left"></i> Orders (Bills)</div>
        <p>View all bills (Draft/Paid/Cancelled), open details, print bill, and verify payment summary.</p>
        <p>Use this as the daily operational checkpoint to ensure no draft is missed.</p>
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-layer-group"></i> Masters</div>
        <p>Maintain menu structure: items, categories, units, and table setup.</p>
        <p>Keep masters clean so POS/KOT screens work accurately for staff.</p>
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-boxes-stacked"></i> Inventory</div>
        <p>Track stock levels and reorder indicators to avoid item unavailability during service.</p>
        <p>Review low-stock cards regularly before peak hours.</p>
      </div>

      <div class="process-guide-card">
        <div class="process-guide-title"><i class="fas fa-table-cells-large"></i> Dashboard & Reports</div>
        <p>Use Dashboard for live KPIs. Use Daily Sales/Bill Wise/Day Close reports for end-of-day reconciliation.</p>
        <p>This is the final step to verify operations, cash flow, and performance trends.</p>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
  <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
  <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
  <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
  @if (ViewBag.UseSelect2 == true)
  {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  }
  @if (ViewBag.UseCharts == true)
  {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  }
  @if (ViewBag.UseSignalR == true)
  {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
  }
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="~/js/site.js" asp-append-version="true"></script>
  <script>
    // Ensure any Bootstrap modal markup declared inside page layout
    // gets moved under <body> on show, fixing stacking/blur issues.
    document.addEventListener('show.bs.modal', function (e) {
      const modalEl = e.target;
      if (!(modalEl instanceof HTMLElement)) return;
      if (modalEl.parentElement !== document.body) {
        document.body.appendChild(modalEl);
      }
    }, true);
  </script>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      if (typeof toastr === "undefined") return;

      const successAlert = document.querySelector(".alert-custom.success");
      if (successAlert) {
        const text = (successAlert.textContent || "").trim();
        if (text) toastr.success(text);
      }

      const errorAlert = document.querySelector(".alert-custom.error");
      if (errorAlert) {
        const text = (errorAlert.textContent || "").trim();
        if (text) toastr.error(text);
      }
    });
  </script>
  @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
