@using Microsoft.AspNetCore.Identity
@using System.Linq
@inject SignInManager<IdentityUser<int>> SignInManager
@inject UserManager<IdentityUser<int>> UserManager
@{
  var path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
  bool IsActive(string prefix) => path.StartsWith(prefix);
  string LinkClass(string prefix) => IsActive(prefix) ? "nav-link-item active" : "nav-link-item";
  string ParentClass(params string[] prefixes) => prefixes.Any(IsActive) ? "nav-link-item open active" : "nav-link-item";
  string SubClass(params string[] prefixes) => prefixes.Any(IsActive) ? "sub-nav" : "sub-nav d-none";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>@ViewData["Title"] | RestoBill</title>
  <meta name="theme-color" content="#0F172A"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="~/lib/font-awesome/6.5.0/css/all.min.css" asp-append-version="true"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet"/>
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet"/>
  <link href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" rel="stylesheet"/>
  @if (ViewBag.UseSelect2 == true) {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet"/>
  }
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@if (SignInManager.IsSignedIn(User))
{
<div class="app-shell">
  <aside class="sidebar" id="appSidebar">
    <div class="sidebar-logo">
      <div class="logo-icon"><i class="fas fa-utensils"></i></div>
      <span class="logo-text">RestoBill</span>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-group">
        <div class="nav-group-label">Overview</div>
        <a class="@LinkClass("/dashboard")" href="/dashboard"><i class="nav-icon fas fa-gauge-high"></i><span class="nav-label">Dashboard</span></a>
      </div>
      <div class="nav-group">
        <div class="nav-group-label">Orders</div>
        <div class="nav-item">
          <div class="@ParentClass("/billing")" data-submenu="billingMenu">
            <i class="nav-icon fas fa-receipt"></i><span class="nav-label">Billing</span><i class="nav-arrow fas fa-chevron-right"></i>
          </div>
          <div class="@SubClass("/billing")" id="billingMenu">
            <a class="@LinkClass("/billing/dinein")" href="/billing/dinein"><i class="nav-icon fas fa-chair"></i><span class="nav-label">Dine-In POS</span></a>
            <a class="@LinkClass("/billing/takeaway")" href="/billing/takeaway"><i class="nav-icon fas fa-shopping-bag"></i><span class="nav-label">Takeaway</span></a>
            <a class="@LinkClass("/billing/quote")" href="/billing/quote"><i class="nav-icon fas fa-file-lines"></i><span class="nav-label">Quote / Estimate</span></a>
            <a class="@LinkClass("/billing/bills")" href="/billing/bills"><i class="nav-icon fas fa-list-ul"></i><span class="nav-label">All Bills</span></a>
          </div>
        </div>
        <div class="nav-item">
          <div class="@ParentClass("/kitchen")" data-submenu="kitchenMenu">
            <i class="nav-icon fas fa-fire-burner"></i><span class="nav-label">Kitchen</span><i class="nav-arrow fas fa-chevron-right"></i>
          </div>
          <div class="@SubClass("/kitchen")" id="kitchenMenu">
            <a class="@LinkClass("/kitchen/kotlist")" href="/kitchen/kotlist"><i class="nav-icon fas fa-ticket"></i><span class="nav-label">KOT List</span></a>
            <a class="@LinkClass("/kitchen/kdsscreen")" href="/kitchen/kdsscreen" target="_blank"><i class="nav-icon fas fa-display"></i><span class="nav-label">KDS Screen ↗</span></a>
          </div>
        </div>
      </div>
      <div class="nav-group">
        <div class="nav-group-label">Stock</div>
        <div class="nav-item">
          <div class="@ParentClass("/stock")" data-submenu="stockMenu">
            <i class="nav-icon fas fa-boxes-stacked"></i><span class="nav-label">Stock</span><i class="nav-arrow fas fa-chevron-right"></i>
          </div>
          <div class="@SubClass("/stock")" id="stockMenu">
            <a class="@LinkClass("/stock/balance")" href="/stock/balance"><i class="nav-icon fas fa-warehouse"></i><span class="nav-label">Stock Balance</span></a>
            <a class="@LinkClass("/stock/purchase")" href="/stock/purchase"><i class="nav-icon fas fa-truck-ramp-box"></i><span class="nav-label">Purchase / GRN</span></a>
            <a class="@LinkClass("/stock/adjustment")" href="/stock/adjustment"><i class="nav-icon fas fa-sliders"></i><span class="nav-label">Adjustment</span></a>
            <a class="@LinkClass("/stock/loss")" href="/stock/loss"><i class="nav-icon fas fa-trash-can"></i><span class="nav-label">Stock Loss</span></a>
          </div>
        </div>
      </div>
      <div class="nav-group">
        <div class="nav-group-label">Reports</div>
        <div class="nav-item">
          <div class="@ParentClass("/reports")" data-submenu="reportsMenu">
            <i class="nav-icon fas fa-chart-bar"></i><span class="nav-label">Reports</span><i class="nav-arrow fas fa-chevron-right"></i>
          </div>
          <div class="@SubClass("/reports")" id="reportsMenu">
            <a class="@LinkClass("/reports/dailysales")" href="/reports/dailysales"><i class="nav-icon fas fa-calendar-day"></i><span class="nav-label">Daily Sales</span></a>
            <a class="@LinkClass("/reports/billwise")" href="/reports/billwise"><i class="nav-icon fas fa-file-invoice"></i><span class="nav-label">Bill Wise</span></a>
            <a class="@LinkClass("/reports/itemwise")" href="/reports/itemwise"><i class="nav-icon fas fa-chart-pie"></i><span class="nav-label">Item Wise</span></a>
            <a class="@LinkClass("/reports/paymentmode")" href="/reports/paymentmode"><i class="nav-icon fas fa-credit-card"></i><span class="nav-label">Payment Mode</span></a>
            <a class="@LinkClass("/reports/stockreport")" href="/reports/stockreport"><i class="nav-icon fas fa-boxes-stacked"></i><span class="nav-label">Stock Report</span></a>
            <a class="@LinkClass("/reports/stockloss")" href="/reports/stockloss"><i class="nav-icon fas fa-arrow-trend-down"></i><span class="nav-label">Stock Loss</span></a>
          </div>
        </div>
      </div>
      <div class="nav-group">
        <div class="nav-group-label">Setup</div>
        <div class="nav-item">
          <div class="@ParentClass("/masters")" data-submenu="mastersMenu">
            <i class="nav-icon fas fa-database"></i><span class="nav-label">Masters</span><i class="nav-arrow fas fa-chevron-right"></i>
          </div>
          <div class="@SubClass("/masters")" id="mastersMenu">
            <a class="@LinkClass("/masters/categories")" href="/masters/categories"><i class="nav-icon fas fa-layer-group"></i><span class="nav-label">Categories</span></a>
            <a class="@LinkClass("/masters/items")" href="/masters/items"><i class="nav-icon fas fa-bowl-food"></i><span class="nav-label">Items</span></a>
            <a class="@LinkClass("/masters/tables")" href="/masters/tables"><i class="nav-icon fas fa-table-cells-large"></i><span class="nav-label">Tables</span></a>
            <a class="@LinkClass("/masters/customers")" href="/masters/customers"><i class="nav-icon fas fa-user-group"></i><span class="nav-label">Customers</span></a>
            <a class="@LinkClass("/masters/suppliers")" href="/masters/suppliers"><i class="nav-icon fas fa-truck"></i><span class="nav-label">Suppliers</span></a>
            <a class="@LinkClass("/masters/taxes")" href="/masters/taxes"><i class="nav-icon fas fa-percent"></i><span class="nav-label">Taxes</span></a>
            <a class="@LinkClass("/masters/units")" href="/masters/units"><i class="nav-icon fas fa-ruler"></i><span class="nav-label">Units</span></a>
            <a class="@LinkClass("/masters/printers")" href="/masters/printers"><i class="nav-icon fas fa-print"></i><span class="nav-label">Printers</span></a>
          </div>
        </div>
        <a class="@LinkClass("/dayclose")" href="/dayclose"><i class="nav-icon fas fa-moon"></i><span class="nav-label">Day Close</span></a>
        <a class="@LinkClass("/settings")" href="/settings"><i class="nav-icon fas fa-gear"></i><span class="nav-label">Settings</span></a>
        <a class="@LinkClass("/admin/users")" href="/admin/users"><i class="nav-icon fas fa-users"></i><span class="nav-label">Users</span></a>
      </div>
    </nav>
    <div class="sidebar-footer">
      <form asp-controller="Account" asp-action="Logout" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="nav-link-item w-100 border-0" style="text-align:left; background:rgba(239,68,68,0.08); border-radius:var(--radius-sm);">
          <i class="nav-icon fas fa-right-from-bracket" style="color:#EF4444;"></i>
          <span class="nav-label" style="color:#EF4444; font-weight:600;">Logout</span>
        </button>
      </form>
    </div>
  </aside>

  <div class="main-wrapper">
    <header class="topbar">
      <button class="topbar-toggle" id="sidebarToggle" title="Toggle sidebar"><i class="fas fa-bars"></i></button>
      <span class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
      <div class="topbar-spacer"></div>
      <div class="topbar-clock" id="liveClock"></div>
      <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme"><i id="themeIcon" class="fas fa-moon"></i></button>
      <div class="topbar-user" id="userDropdown">
        <div class="avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "A")</div>
        <span class="uname d-none d-md-inline">@User.Identity?.Name</span>
      </div>
    </header>
    <main class="main-content">
      @if (TempData["Success"] != null)
      { <div class="alert-custom success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div> }
      @if (TempData["Error"] != null)
      { <div class="alert-custom error"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div> }
      @RenderBody()
    </main>
  </div>
</div>
}
else
{
  <div class="container py-4">@RenderBody()</div>
}

@{
  var toastMessage = TempData["ToastMessage"] as string;
  var toastType = TempData["ToastType"] as string ?? "info";
  var toastClass = toastType switch
  {
    "success" => "text-bg-success",
    "danger" => "text-bg-danger",
    "warning" => "text-bg-warning",
    _ => "text-bg-primary"
  };
}
@if (!string.IsNullOrWhiteSpace(toastMessage))
{
  <div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="app-toast" class="toast @toastClass border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="3500">
      <div class="d-flex">
        <div class="toast-body">@toastMessage</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
  </div>
}

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
@if (ViewBag.UseSelect2 == true) {
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
}
@if (ViewBag.UseCharts == true) {
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}
@if (ViewBag.UseSignalR == true) {
  <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
}
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
