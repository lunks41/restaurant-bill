@{
    ViewData["Title"] = "Dine-In POS";
}

<div class="app-module-header">
    <h1 class="h3 mb-1">Billing</h1>
    <p class="app-muted mb-0">Dine-in order taking, holding, KOT and settlement flow.</p>
</div>
<nav class="nav app-module-tabs gap-1">
    <a class="nav-link active" asp-controller="Billing" asp-action="DineIn"><i class="fas fa-chair"></i> Dine-In POS</a>
    <a class="nav-link" asp-controller="Billing" asp-action="Takeaway"><i class="fas fa-shopping-bag"></i> Takeaway</a>
    <a class="nav-link" asp-controller="Billing" asp-action="Quote"><i class="fas fa-file-lines"></i> Quote</a>
    <a class="nav-link" asp-controller="Billing" asp-action="BillList"><i class="fas fa-list-ul"></i> Bills</a>
</nav>

<div id="posRoot" class="pos-layout">
    <aside class="pos-cats" id="posCategories"></aside>

    <section class="pos-items-panel">
        <div class="pos-search-bar">
            <div class="pos-search-wrap">
                <i class="fas fa-magnifying-glass"></i>
                <input id="posSearch" class="pos-search-input" placeholder="Search items..." autocomplete="off" />
            </div>
            <span class="pos-items-count" id="posItemsCount"></span>
        </div>
        <div class="pos-items-grid" id="posItems"></div>
    </section>

    <aside class="pos-cart">
        <div class="cart-header">
            <div class="cart-header-icon"><i class="fas fa-receipt"></i></div>
            <div class="cart-header-info">
                <div class="cart-header-title">Current Bill</div>
                <div class="cart-bill-no" id="cartBillLabel">Dine-In &mdash; New Order</div>
            </div>
        </div>
        <div class="cart-meta">
            <button class="cart-meta-btn selected" id="btnTable"><i class="fas fa-chair"></i> Table</button>
            <button class="cart-meta-btn" id="btnCustomer"><i class="fas fa-user"></i> Customer</button>
            <button class="cart-meta-btn" id="btnDiscount"><i class="fas fa-tag"></i> Discount</button>
        </div>
        <div class="cart-items" id="posCartItems"></div>
        <div class="cart-totals">
            <div class="cart-total-row"><span>Subtotal</span><span id="posSubTotal">&#8377;0.00</span></div>
            <div class="cart-total-row"><span>Tax</span><span id="posTaxTotal">&#8377;0.00</span></div>
            <div class="cart-total-row grand"><span>Grand Total</span><span class="grand-amt" id="posGrandTotal">&#8377;0.00</span></div>
        </div>
        <div class="cart-actions">
            <button class="btn-settle" id="btnSettle"><i class="fas fa-indian-rupee-sign"></i> Settle Bill</button>
            <button class="btn-kot" id="btnKot"><i class="fas fa-fire-burner"></i> KOT</button>
            <button class="btn-hold" id="btnHold"><i class="fas fa-pause"></i> Hold</button>
        </div>
        <div class="cart-actions-secondary">
            <button class="btn-recall" id="btnRecall">
                <i class="fas fa-rotate-left"></i> Recall
                <span class="recall-badge" id="recallBadge" style="display:none;">0</span>
            </button>
            <button class="btn-new-order" id="btnNewOrder">
                <i class="fas fa-plus"></i> New Order
            </button>
        </div>
    </aside>
</div>

<!-- Settle Bill Modal -->
<div class="settle-modal-overlay" id="settleOverlay">
    <div class="settle-modal">
        <div class="settle-modal-head">
            <h3><i class="fas fa-indian-rupee-sign me-2"></i>Settle Bill</h3>
            <button class="settle-modal-close" id="settleClose">&times;</button>
        </div>
        <div class="settle-modal-body">
            <div class="settle-summary" id="settleSummary"></div>
            <div class="settle-pay-label">Select Payment Method</div>
            <div class="settle-pay-grid">
                <div class="settle-pay-btn active" data-method="Cash">
                    <i class="fas fa-money-bill-wave"></i><span>Cash</span>
                </div>
                <div class="settle-pay-btn" data-method="Card">
                    <i class="fas fa-credit-card"></i><span>Card</span>
                </div>
                <div class="settle-pay-btn" data-method="UPI">
                    <i class="fas fa-mobile-screen"></i><span>UPI</span>
                </div>
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Amount Received</label>
                <input type="number" id="settleAmtInput" class="form-control-custom" step="0.01" />
            </div>
            <div id="settleChangeRow" style="display:none; background:var(--success-bg); border-radius:var(--radius-sm); padding:10px 14px; font-size:13px; font-weight:600; color:var(--success); margin-top:8px;">
                <i class="fas fa-coins me-1"></i>Change: <span id="settleChangeDue">&#8377;0.00</span>
            </div>
        </div>
        <div class="settle-modal-foot">
            <button class="btn-settle-cancel" id="settleCancelBtn">Cancel</button>
            <button class="btn-settle-confirm" id="settleConfirmBtn">
                <i class="fas fa-check-circle"></i> Confirm &amp; Print
            </button>
        </div>
    </div>
</div>

<!-- Hidden print receipt -->
<div class="receipt-wrap" id="receiptWrap"></div>

<!-- Table Picker Panel -->
<div class="side-panel-overlay" id="tablePanelOverlay">
    <div class="side-panel side-panel-md">
        <div class="side-panel-head">
            <h3><i class="fas fa-chair me-2"></i>Select Table</h3>
            <button class="side-panel-close" id="tablePanelClose">&times;</button>
        </div>
        <div class="side-panel-body">
            <p class="text-muted small mb-3">Tap a free table to assign it to the current order. Occupied tables have an active held bill.</p>
            <div class="table-pick-grid" id="tableGrid">
                <div style="padding:24px;text-align:center;color:var(--text-muted);">Loading tables&hellip;</div>
            </div>
        </div>
    </div>
</div>

<!-- Held Bills Recall Panel -->
<div class="side-panel-overlay" id="recallPanelOverlay">
    <div class="side-panel side-panel-md">
        <div class="side-panel-head">
            <h3><i class="fas fa-rotate-left me-2"></i>Held Bills</h3>
            <button class="side-panel-close" id="recallPanelClose">&times;</button>
        </div>
        <div class="side-panel-body">
            <p class="text-muted small mb-3">Select a held bill to load it back into the POS for editing or settlement.</p>
            <div class="recall-list" id="recallList">
                <div style="padding:24px;text-align:center;color:var(--text-muted);">Loading held bills&hellip;</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pos.js" asp-append-version="true"></script>
}
