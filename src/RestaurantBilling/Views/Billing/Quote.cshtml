@{
    ViewData["Title"] = "Quote";
}

<div class="page-header">
    <div>
        <h1 class="page-title-h">Quote / Estimate</h1>
        <div class="page-sub">Create and convert quotations into bills.</div>
    </div>
</div>

<div class="card">
    <div class="card-body-custom">
        <form class="row g-3" onsubmit="return false;">
            <div class="col-md-4">
                <label class="form-label-custom">Customer</label>
                <input id="quoteCustomer" class="form-control-custom" placeholder="Walk-in customer" />
            </div>
            <div class="col-md-3">
                <label class="form-label-custom">Business Date</label>
                <input id="quoteDate" type="date" class="form-control-custom" />
            </div>
            <div class="col-md-5">
                <label class="form-label-custom">Notes</label>
                <input id="quoteItem" class="form-control-custom" placeholder="Item name" />
            </div>
            <div class="col-md-2"><input id="quoteQty" type="number" class="form-control-custom" placeholder="Qty" value="1" /></div>
            <div class="col-md-2"><input id="quoteRate" type="number" class="form-control-custom" placeholder="Rate" value="100" /></div>
            <div class="col-md-2"><button id="saveQuote" class="btn-accent">Create Quote</button></div>
        </form>
    </div>
</div>
<div class="card mt-3"><div class="card-body-custom"><table class="table-custom"><thead><tr><th>Quote No</th><th>Date</th><th>Total</th><th>Status</th><th>Action</th></tr></thead><tbody id="quoteRows"><tr><td colspan="5" class="text-center text-muted">No quotes</td></tr></tbody></table></div></div>

@section Scripts {
<script>
(() => {
  const qDate = document.getElementById('quoteDate');
  qDate.value = new Date().toISOString().slice(0,10);

  async function loadQuotes() {
    const rows = await getJSON('/billing/quotes-data?outletId=1');
    document.getElementById('quoteRows').innerHTML = rows.length
      ? rows.map(x => `<tr><td>${x.quoteNo}</td><td>${x.businessDate}</td><td>${fmtINR(x.grandTotal)}</td><td>${x.status}</td><td><button class="btn-ghost" data-id="${x.quotationId}">Convert</button></td></tr>`).join('')
      : '<tr><td colspan="5" class="text-center text-muted">No quotes</td></tr>';
    document.querySelectorAll('#quoteRows button[data-id]').forEach(b => b.addEventListener('click', async () => {
      await postJSON(`/billing/quote/${b.dataset.id}/convert`, {});
      toastr.success('Quote converted to bill.');
      loadQuotes();
    }));
  }

  async function saveQuote() {
    await postJSON('/billing/quote', {
      outletId: 1,
      businessDate: qDate.value,
      billLevelDiscount: 0,
      items: [{
        itemId: 1, itemName: document.getElementById('quoteItem').value || 'Quote Item',
        qty: parseFloat(document.getElementById('quoteQty').value || '1'),
        rate: parseFloat(document.getElementById('quoteRate').value || '100'),
        discountAmount: 0, taxPercent: 5, isTaxInclusive: false, taxType: 'GST'
      }]
    });
    toastr.success('Quote created.');
    loadQuotes();
  }

  document.getElementById('saveQuote').addEventListener('click', saveQuote);
  document.addEventListener('DOMContentLoaded', loadQuotes);
})();
</script>
}
