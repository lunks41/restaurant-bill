@{
    ViewData["Title"] = "Tables";
}

<partial name="_MastersCoreTabs" />

<div class="app-surface mb-3 d-flex justify-content-end">
    <div class="me-2" style="min-width: 220px;">
        <select id="tableAreaFilter" class="form-select">
            <option value="">All areas</option>
            <option value="Ground">Ground</option>
            <option value="AC">AC</option>
            <option value="Non-AC">Non-AC</option>
            <option value="Outdoor">Outdoor</option>
        </select>
    </div>
    <button type="button" class="btn-accent" id="openAddTable">
        <i class="fas fa-plus"></i> Add Table
    </button>
</div>
<div class="card">
    <div class="card-body-custom">
        <table id="tablesTable" class="table-custom">
            <thead>
                <tr><th>Table</th><th>Area</th><th>Capacity</th><th>Status</th><th>State</th><th></th></tr>
            </thead>
            <tbody id="tablesBody"><tr><td colspan="6" class="text-center text-muted">No tables added.</td></tr></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="tableModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tableModalTitle">Add Table</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input id="tableId" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">Table name</label>
                    <input id="tableName" class="form-control" placeholder="Table name"/>
                </div>
                <div class="mb-3">
                    <label class="form-label">Area</label>
                    <select id="tableArea" class="form-select">
                        <option value="Ground">Ground</option>
                        <option value="AC">AC</option>
                        <option value="Non-AC">Non-AC</option>
                        <option value="Outdoor">Outdoor</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Capacity</label>
                    <input id="capacity" type="number" class="form-control" placeholder="Capacity"/>
                </div>
                <div class="mt-3">
                    <div class="form-check">
                        <input id="tableIsActive" type="checkbox" class="form-check-input" checked />
                        <label class="form-check-label" for="tableIsActive">Is Active</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTable">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const modalEl = document.getElementById('tableModal');
  if (!modalEl || !window.bootstrap) return;
  const modal = new window.bootstrap.Modal(modalEl);
  const idEl = document.getElementById('tableId');
  const nameEl = document.getElementById('tableName');
  const areaEl = document.getElementById('tableArea');
  const areaFilterEl = document.getElementById('tableAreaFilter');
  const capacityEl = document.getElementById('capacity');
  const isActiveEl = document.getElementById('tableIsActive');
  const titleEl = document.getElementById('tableModalTitle');
  const saveBtnEl = document.getElementById('saveTable');
  let dataTable = null;

  const notifySafe = (message, type = 'info') => {
    if (typeof window.notify === 'function') {
      window.notify(message, type);
      return;
    }
    if (typeof toastr !== 'undefined' && typeof toastr[type] === 'function') {
      toastr[type](message);
    }
  };

  async function load() {
    const rows = await getJSON(`/masters/tables-data?outletId=1&_=${Date.now()}`);
    if (window.jQuery && jQuery.fn.DataTable) {
      const table = jQuery('#tablesTable');
      if (jQuery.fn.dataTable.isDataTable(table)) {
        table.DataTable().destroy();
      }
    }
    document.getElementById('tablesBody').innerHTML = rows.length ? rows.map(x => `<tr><td>${x.tableName}</td><td>${x.area}</td><td>${x.capacity}</td><td>${x.isOccupied ? 'Occupied' : 'Available'}</td><td>${x.isActive ? '<span class="badge-custom badge-success">Active</span>' : '<span class="badge-custom badge-muted">Inactive</span>'}</td><td><button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.tableMasterId}" data-name="${x.tableName}" data-area="${x.area}" data-capacity="${x.capacity}" data-is-active="${x.isActive}">Edit</button><button class="btn btn-sm btn-outline-danger" data-delete="${x.tableMasterId}">Delete</button></td></tr>`).join('') : '<tr><td colspan="6" class="text-center text-muted">No tables added.</td></tr>';
    bindRowActions();
    if (window.jQuery && jQuery.fn.DataTable) {
      const table = jQuery('#tablesTable');
      const hasPlaceholderRow = !!document.querySelector('#tablesBody td[colspan]');
      if (hasPlaceholderRow) {
        dataTable = null;
      } else {
        dataTable = table.DataTable({
          pageLength: 10,
          responsive: true
        });
        applyAreaFilter();
      }
    }
  }

  const applyAreaFilter = () => {
    if (!dataTable) return;
    const selected = areaFilterEl?.value || '';
    dataTable.column(1).search(selected ? `^${selected}$` : '', true, false).draw();
  };

  const openAdd = () => {
    idEl.value = '';
    nameEl.value = '';
    areaEl.value = 'Ground';
    capacityEl.value = '';
    isActiveEl.checked = true;
    titleEl.textContent = 'Add Table';
    saveBtnEl.textContent = 'Add';
    modal.show();
  };

  const openEdit = (btn) => {
    idEl.value = btn.getAttribute('data-edit') || '';
    nameEl.value = btn.getAttribute('data-name') || '';
    areaEl.value = btn.getAttribute('data-area') || 'Ground';
    capacityEl.value = btn.getAttribute('data-capacity') || '';
    isActiveEl.checked = (btn.getAttribute('data-is-active') !== 'false');
    titleEl.textContent = 'Edit Table';
    saveBtnEl.textContent = 'Update';
    modal.show();
  };

  async function save() {
    const tableName = nameEl.value.trim();
    if (!tableName) {
      notifySafe('Table name is required', 'warning');
      return;
    }

    const id = idEl.value;
    const area = areaEl.value || 'Ground';
    const capacity = parseInt(capacityEl.value || '2', 10);
    try {
      if (id) {
        await postJSON(`/masters/tables-update/${id}`, { name: tableName, area, capacity, isActive: isActiveEl.checked });
        notifySafe('Table updated', 'success');
      } else {
        await postJSON('/masters/tables-create', { name: tableName, area, capacity, isActive: isActiveEl.checked });
        notifySafe('Table added', 'success');
      }
      modal.hide();
      await load();
    } catch (_) {
      notifySafe('Unable to save table right now', 'error');
    }
  }

  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => openEdit(btn)));
    document.querySelectorAll('[data-delete]').forEach(btn => btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-delete');
      if (!id) return;
      confirmAction('Delete this table? It will be marked as inactive.', async () => {
        await postJSON(`/masters/tables-delete/${id}`, { name: '' });
        notifySafe('Table deleted (inactive)', 'success');
        await load();
      });
    }));
  }

  document.getElementById('openAddTable')?.addEventListener('click', openAdd);
  areaFilterEl?.addEventListener('change', applyAreaFilter);
  saveBtnEl.addEventListener('click', save);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', load);
  } else {
    load();
  }
})();
</script>
}
