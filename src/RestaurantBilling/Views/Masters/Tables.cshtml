@{
    ViewData["Title"] = "Tables";
}
<div class="app-module-header">
    <h1 class="h3 mb-1">Masters</h1>
    <p class="app-muted mb-0">Manage core menu and taxation setup.</p>
</div>
<nav class="nav app-module-tabs gap-2">
    <a class="nav-link" asp-controller="Masters" asp-action="Categories">Categories</a><a class="nav-link" asp-controller="Masters" asp-action="Items">Items</a><a class="nav-link active" asp-controller="Masters" asp-action="Tables">Tables</a><a class="nav-link" asp-controller="Masters" asp-action="Customers">Customers</a><a class="nav-link" asp-controller="Masters" asp-action="Suppliers">Suppliers</a><a class="nav-link" asp-controller="Masters" asp-action="Taxes">Taxes</a><a class="nav-link" asp-controller="Masters" asp-action="Units">Units</a><a class="nav-link" asp-controller="Masters" asp-action="Printers">Printers</a>
</nav>
<div class="card mb-3"><div class="card-body-custom"><div class="row g-2"><div class="col-md-5"><input id="tableName" class="form-control-custom" placeholder="Table name"/></div><div class="col-md-3"><input id="capacity" type="number" class="form-control-custom" placeholder="Capacity"/></div><div class="col-md-2"><button id="saveTable" class="btn-accent">Add Table</button></div></div></div></div>
<div class="card"><div class="card-body-custom"><table id="tablesTable" class="table-custom"><thead><tr><th>Table</th><th>Capacity</th><th>Status</th><th></th></tr></thead><tbody id="tablesBody"><tr><td colspan="4" class="text-center text-muted">No tables added.</td></tr></tbody></table></div></div>

@section Scripts {
<script>
(() => {
  async function load() {
    const rows = await getJSON('/masters/tables-data?outletId=1');
    document.getElementById('tablesBody').innerHTML = rows.length ? rows.map(x => `<tr><td>${x.tableName}</td><td>${x.capacity}</td><td>${x.isOccupied ? 'Occupied' : 'Available'}</td><td><button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.tableMasterId}" data-name="${x.tableName}" data-capacity="${x.capacity}">Edit</button><button class="btn btn-sm btn-outline-danger" data-delete="${x.tableMasterId}">Delete</button></td></tr>`).join('') : '<tr><td colspan="4" class="text-center text-muted">No tables added.</td></tr>';
    bindRowActions();
    if (window.refreshDataTableById) window.refreshDataTableById('tablesTable');
  }
  async function save() {
    await postJSON('/masters/tables-create', { name: document.getElementById('tableName').value, capacity: parseInt(document.getElementById('capacity').value || '2', 10) });
    toastr.success('Table added');
    await load();
  }
  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-edit');
      const currentName = btn.getAttribute('data-name');
      const currentCapacity = btn.getAttribute('data-capacity');
      const name = prompt('Edit table name', currentName);
      if (!name) return;
      const capText = prompt('Edit capacity', currentCapacity);
      const capacity = parseInt(capText || currentCapacity, 10);
      await postJSON(`/masters/tables-update/${id}`, { name, capacity });
      toastr.success('Table updated');
      await load();
    }));
    document.querySelectorAll('[data-delete]').forEach(btn => btn.addEventListener('click', async () => {
      if (!confirm('Delete this table?')) return;
      await postJSON(`/masters/tables-delete/${btn.getAttribute('data-delete')}`, { name: '' });
      toastr.success('Table deleted');
      await load();
    }));
  }
  document.getElementById('saveTable').addEventListener('click', save);
  document.addEventListener('DOMContentLoaded', load);
})();
</script>
}
