<div class="app-module-header">
  <h1 class="h3 mb-1">Masters</h1>
  <p class="app-muted mb-0">Manage core menu and taxation setup.</p>
</div>

<div class="app-surface mb-3 d-flex justify-content-end">
  <button type="button" class="btn-accent" id="openAddPrinter">
    <i class="fas fa-plus"></i> Add Printer
  </button>
</div>
<div class="card">
  <div class="card-body-custom">
    <table id="printersTable" class="table-custom">
      <thead>
        <tr>
          <th>Name</th>
          <th>Type</th>
          <th>Path</th>
          <th>Default</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="printersBody">
        <tr>
          <td colspan="6" class="text-center text-muted">No printers found.</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<div class="modal fade" id="printerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="printerModalTitle">Add Printer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <input id="printerId" type="hidden" />
        <div class="mb-3">
          <label class="form-label">Printer name</label>
          <input id="printerName" class="form-control" placeholder="Printer name" />
        </div>
        <div class="mb-3">
          <label class="form-label">Printer type</label>
          <select id="printerType" class="form-select">
            <option>Thermal</option>
            <option>A4</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Device path</label>
          <input id="devicePath" class="form-control" placeholder="Device path" />
        </div>
        <div class="form-check">
          <input id="isDefault" class="form-check-input" type="checkbox" />
          <label class="form-check-label" for="isDefault">Default printer</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="savePrinter">Save</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    (() => {
      const modalEl = document.getElementById('printerModal');
      if (!modalEl || !window.bootstrap) return;
      const modal = new window.bootstrap.Modal(modalEl);
      const idEl = document.getElementById('printerId');
      const nameEl = document.getElementById('printerName');
      const typeEl = document.getElementById('printerType');
      const pathEl = document.getElementById('devicePath');
      const defaultEl = document.getElementById('isDefault');
      const titleEl = document.getElementById('printerModalTitle');
      const saveBtnEl = document.getElementById('savePrinter');

      const notifySafe = (message, type = 'info') => {
        if (typeof window.notify === 'function') {
          window.notify(message, type);
          return;
        }
        if (typeof toastr !== 'undefined' && typeof toastr[type] === 'function') {
          toastr[type](message);
        }
      };

      async function load() {
        const rows = await getJSON('/masters/printers-data?outletId=1');
        document.getElementById('printersBody').innerHTML = rows.length ? rows.map(x => `<tr><td>${x.printerName}</td><td>${x.printerType}</td><td>${x.devicePath || ''}</td><td>${x.isDefault ? 'Yes' : 'No'}</td><td>${x.isActive ? '<span class="badge-custom badge-success">Active</span>' : '<span class="badge-custom badge-muted">Inactive</span>'}</td><td><button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.printerProfileId}" data-name="${x.printerName}" data-type="${x.printerType}" data-path="${x.devicePath || ''}" data-default="${x.isDefault ? 'true' : 'false'}">Edit</button><button class="btn btn-sm btn-outline-danger" data-delete="${x.printerProfileId}">Inactivate</button></td></tr>`).join('') : '<tr><td colspan="6" class="text-center text-muted">No printers found.</td></tr>';
        bindRowActions();
        if (window.refreshDataTableById) window.refreshDataTableById('printersTable');
      }

      const openAdd = () => {
        idEl.value = '';
        nameEl.value = '';
        typeEl.value = 'Thermal';
        pathEl.value = '';
        defaultEl.checked = false;
        titleEl.textContent = 'Add Printer';
        saveBtnEl.textContent = 'Add';
        modal.show();
      };

      const openEdit = (btn) => {
        idEl.value = btn.getAttribute('data-edit') || '';
        nameEl.value = btn.getAttribute('data-name') || '';
        typeEl.value = btn.getAttribute('data-type') || 'Thermal';
        pathEl.value = btn.getAttribute('data-path') || '';
        defaultEl.checked = btn.getAttribute('data-default') === 'true';
        titleEl.textContent = 'Edit Printer';
        saveBtnEl.textContent = 'Update';
        modal.show();
      };

      async function save() {
        const printerName = nameEl.value.trim();
        if (!printerName) {
          notifySafe('Printer name is required', 'warning');
          return;
        }

        const payload = { name: printerName, printerType: typeEl.value, devicePath: pathEl.value, isDefault: defaultEl.checked };
        const id = idEl.value;
        try {
          if (id) {
            await postJSON(`/masters/printers-update/${id}`, payload);
            notifySafe('Printer updated', 'success');
          } else {
            await postJSON('/masters/printers-create', payload);
            notifySafe('Printer added', 'success');
          }
          modal.hide();
          await load();
        } catch (_) {
          notifySafe('Unable to save printer right now', 'error');
        }
      }

      function bindRowActions() {
        document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => openEdit(btn)));
        document.querySelectorAll('[data-delete]').forEach(btn => btn.addEventListener('click', async () => {
          if (!confirm('Inactivate this printer?')) return;
          try {
            await postJSON(`/masters/printers-delete/${btn.getAttribute('data-delete')}`, { name: '' });
            notifySafe('Printer inactivated', 'success');
            await load();
          } catch (_) {
            notifySafe('Unable to inactivate printer right now', 'error');
          }
        }));
      }

      document.getElementById('openAddPrinter')?.addEventListener('click', openAdd);
      saveBtnEl.addEventListener('click', save);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', load);
      } else {
        load();
      }
    })();
  </script>
}
