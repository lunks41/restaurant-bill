@{
    ViewData["Title"] = "Groceries & Unit";
}

<div class="app-module-header">
    <h1 class="h3 mb-1">Groceries & Unit</h1>
    <p class="app-muted mb-0">Manage both screens here using Bootstrap tabs.</p>
</div>

<div class="card p-2">
    <div class="card-body-custom">
        <ul class="nav nav-tabs mb-2" id="groceryUnitTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="groceries-tab" data-bs-toggle="tab" data-bs-target="#groceries-pane" type="button" role="tab">
                    <i class="fas fa-cart-shopping me-1"></i> Groceries
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="units-tab" data-bs-toggle="tab" data-bs-target="#units-pane" type="button" role="tab">
                    <i class="fas fa-ruler me-1"></i> Unit
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="groceries-pane" role="tabpanel" aria-labelledby="groceries-tab">
                <iframe src="/master/stock?embed=1" title="Groceries" style="width:100%; min-height:72vh; border:0; background:#fff;"></iframe>
            </div>
            <div class="tab-pane fade" id="units-pane" role="tabpanel" aria-labelledby="units-tab">
                <iframe src="/master/units?embed=1" title="Units" style="width:100%; min-height:72vh; border:0; background:#fff;"></iframe>
            </div>
        </div>
    </div>
</div>
