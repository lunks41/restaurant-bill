@model RestaurantBilling.Models.Masters.ItemInputModel
@{
    IEnumerable<RestaurantBilling.Controllers.ItemListRow> rows = ViewBag.Rows as IEnumerable<RestaurantBilling.Controllers.ItemListRow>
        ?? Enumerable.Empty<RestaurantBilling.Controllers.ItemListRow>();
    var categories = (IEnumerable<Entities.Masters.Category>)ViewBag.Categories;
}

<partial name="_MastersCoreTabs" />

<div class="app-surface mb-3 d-flex justify-content-end">
    <button type="button" class="btn-accent" id="openAddItem">
        <i class="fas fa-plus"></i> Add Item
    </button>
</div>

<div class="card">
    <div class="card-body-custom">
    <table id="itemsTable" class="table-custom">
        <thead>
            <tr>
                <th>Image</th>
                <th>Code</th>
                <th>Name</th>
                <th>Category</th>
                <th>Sale</th>
                <th>GST</th>
                <th>IsStock</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in rows)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(row.Item.ImagePath))
                        {
                            <img src="@row.Item.ImagePath" alt="@row.Item.ItemName" style="width:36px;height:36px;object-fit:cover;border-radius:8px;border:1px solid var(--border);" />
                        }
                        else
                        {
                            <span class="badge-custom badge-muted">No image</span>
                        }
                    </td>
                    <td>@row.Item.ItemCode</td>
                    <td>@row.Item.ItemName</td>
                    <td>@row.CategoryName</td>
                    <td>@row.Item.SalePrice.ToString("0.00")</td>
                    <td>@row.Item.GstPercent.ToString("0.00")</td>
                    <td>
                        @if (row.Item.IsStock)
                        {
                            <span class="badge-custom badge-info">Yes</span>
                        }
                        else
                        {
                            <span class="badge-custom badge-muted">No</span>
                        }
                    </td>
                    <td>
                        @if (row.Item.IsActive)
                        {
                            <span class="badge-custom badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge-custom badge-muted">Inactive</span>
                        }
                    </td>
                    <td class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-primary btn-edit-item"
                                data-id="@row.Item.ItemId"
                                data-code="@row.Item.ItemCode"
                                data-name="@row.Item.ItemName"
                                data-category-id="@row.Item.CategoryId"
                                data-sale="@row.Item.SalePrice.ToString("0.00")"
                                data-gst="@row.Item.GstPercent.ToString("0.00")"
                                data-is-active="@row.Item.IsActive.ToString().ToLowerInvariant()"
                                data-is-stock="@row.Item.IsStock.ToString().ToLowerInvariant()"
                                data-tax-inclusive="@row.Item.IsTaxInclusive.ToString().ToLowerInvariant()"
                                data-image-path="@row.Item.ImagePath">
                            Edit
                        </button>
                        <form method="post" action="/masters/items/@row.Item.ItemId/delete" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger btn-delete-item">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>

<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" id="itemForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="itemModalTitle">Add Item</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input asp-for="ItemId" type="hidden" id="modalItemId" />
                    <input asp-for="ImagePath" type="hidden" id="modalImagePath" />

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Code</label>
                            <input asp-for="ItemCode" class="form-control" id="modalItemCode" placeholder="Code" required />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Name</label>
                            <input asp-for="ItemName" class="form-control" id="modalItemName" placeholder="Name" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Category</label>
                            <select asp-for="CategoryId" class="form-select" id="modalCategoryId" required>
                                <option value="">Select category</option>
                                @foreach (var c in categories)
                                {
                                    <option value="@c.CategoryId">@c.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Sale</label>
                            <input asp-for="SalePrice" class="form-control" id="modalSalePrice" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">GST%</label>
                            <input asp-for="GstPercent" class="form-control" id="modalGstPercent" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Item image</label>
                            <input asp-for="ImageFile" type="file" class="form-control" id="modalImageFile" accept=".jpg,.jpeg,.png,.webp,.gif" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="IsTaxInclusive" class="form-check-input" id="modalTaxInclusive" />
                                <label class="form-check-label" for="modalTaxInclusive">Tax inclusive</label>
                            </div>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" id="modalIsActive" />
                                <label class="form-check-label" for="modalIsActive">Is Active</label>
                            </div>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="IsStock" class="form-check-input" id="modalIsStock" />
                                <label class="form-check-label" for="modalIsStock">Is Stock</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <img id="modalImagePreview" src="" alt="Preview" style="display:none;width:72px;height:72px;object-fit:cover;border-radius:10px;border:1px solid var(--border);" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="saveItemBtn">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const modalEl = document.getElementById('itemModal');
  if (!modalEl || !window.bootstrap) return;
  const modal = new window.bootstrap.Modal(modalEl);

  const titleEl = document.getElementById('itemModalTitle');
  const saveBtn = document.getElementById('saveItemBtn');
  const idEl = document.getElementById('modalItemId');
  const codeEl = document.getElementById('modalItemCode');
  const nameEl = document.getElementById('modalItemName');
  const categoryEl = document.getElementById('modalCategoryId');
  const saleEl = document.getElementById('modalSalePrice');
  const gstEl = document.getElementById('modalGstPercent');
  const taxInclusiveEl = document.getElementById('modalTaxInclusive');
  const isActiveEl = document.getElementById('modalIsActive');
  const isStockEl = document.getElementById('modalIsStock');
  const imagePathEl = document.getElementById('modalImagePath');
  const imageFileEl = document.getElementById('modalImageFile');
  const imagePreviewEl = document.getElementById('modalImagePreview');

  const setPreview = (src) => {
    if (!src) {
      imagePreviewEl.style.display = 'none';
      imagePreviewEl.src = '';
      return;
    }
    imagePreviewEl.src = src;
    imagePreviewEl.style.display = 'inline-block';
  };

  const openAdd = () => {
    titleEl.textContent = 'Add Item';
    saveBtn.textContent = 'Add';
    idEl.value = '';
    codeEl.value = '';
    nameEl.value = '';
    categoryEl.value = '';
    saleEl.value = '0.00';
    gstEl.value = '5.00';
    isActiveEl.checked = true;
    isStockEl.checked = false;
    taxInclusiveEl.checked = false;
    imagePathEl.value = '';
    imageFileEl.value = '';
    setPreview('');
    modal.show();
  };

  const openEdit = (btn) => {
    titleEl.textContent = 'Edit Item';
    saveBtn.textContent = 'Update';
    idEl.value = btn.getAttribute('data-id') || '';
    codeEl.value = btn.getAttribute('data-code') || '';
    nameEl.value = btn.getAttribute('data-name') || '';
    categoryEl.value = btn.getAttribute('data-category-id') || '';
    saleEl.value = btn.getAttribute('data-sale') || '0';
    gstEl.value = btn.getAttribute('data-gst') || '0';
    isActiveEl.checked = (btn.getAttribute('data-is-active') !== 'false');
    isStockEl.checked = (btn.getAttribute('data-is-stock') !== 'false');
    taxInclusiveEl.checked = (btn.getAttribute('data-tax-inclusive') === 'true');
    imagePathEl.value = btn.getAttribute('data-image-path') || '';
    imageFileEl.value = '';
    setPreview(imagePathEl.value);
    modal.show();
  };

  document.getElementById('openAddItem')?.addEventListener('click', openAdd);
  document.querySelectorAll('.btn-edit-item').forEach((btn) => btn.addEventListener('click', () => openEdit(btn)));
  document.querySelectorAll('.btn-delete-item').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const deleteForm = btn.closest('form');
      if (!deleteForm) return;
      confirmAction('Delete this item? It will be marked as inactive.', () => deleteForm.submit());
    });
  });

  imageFileEl?.addEventListener('change', (e) => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    setPreview(URL.createObjectURL(file));
  });
})();
</script>
}
