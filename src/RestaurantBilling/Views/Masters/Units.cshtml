@{
    ViewData["Title"] = "Units";
}
<div class="app-module-header">
    <h1 class="h3 mb-1">Masters</h1>
    <p class="app-muted mb-0">Manage core menu and taxation setup.</p>
</div>
<nav class="nav app-module-tabs gap-2">
    <a class="nav-link" asp-controller="Masters" asp-action="Categories">Categories</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Items">Items</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Tables">Tables</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Customers">Customers</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Suppliers">Suppliers</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Taxes">Taxes</a>
    <a class="nav-link active" asp-controller="Masters" asp-action="Units">Units</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Printers">Printers</a>
</nav>
<div class="card mb-3"><div class="card-body-custom"><div class="row g-2"><div class="col-md-5"><input id="unitName" class="form-control-custom" placeholder="Unit name"/></div><div class="col-md-3"><input id="unitCode" class="form-control-custom" placeholder="Code"/></div><div class="col-md-2"><button id="saveUnit" class="btn-accent">Add Unit</button></div></div></div></div>
<div class="card"><div class="card-body-custom"><table id="unitsTable" class="table-custom"><thead><tr><th>Unit Name</th><th>Code</th><th></th></tr></thead><tbody id="unitsBody"><tr><td colspan="3" class="text-center text-muted">No units found.</td></tr></tbody></table></div></div>

@section Scripts {
<script>
(() => {
  async function load() {
    const rows = await getJSON('/masters/units-data?outletId=1');
    document.getElementById('unitsBody').innerHTML = rows.length ? rows.map(x => `<tr><td>${x.unitName}</td><td>${x.unitCode}</td><td><button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.unitId}" data-name="${x.unitName}" data-code="${x.unitCode}">Edit</button><button class="btn btn-sm btn-outline-danger" data-delete="${x.unitId}">Delete</button></td></tr>`).join('') : '<tr><td colspan="3" class="text-center text-muted">No units found.</td></tr>';
    bindRowActions();
    if (window.refreshDataTableById) window.refreshDataTableById('unitsTable');
  }
  async function save() {
    await postJSON('/masters/units-create', { name: document.getElementById('unitName').value, code: document.getElementById('unitCode').value });
    toastr.success('Unit added');
    await load();
  }
  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-edit');
      const name = prompt('Edit unit name', btn.getAttribute('data-name'));
      if (!name) return;
      const code = prompt('Edit unit code', btn.getAttribute('data-code') || '') ?? '';
      await postJSON(`/masters/units-update/${id}`, { name, code });
      toastr.success('Unit updated');
      await load();
    }));
    document.querySelectorAll('[data-delete]').forEach(btn => btn.addEventListener('click', async () => {
      if (!confirm('Delete this unit?')) return;
      await postJSON(`/masters/units-delete/${btn.getAttribute('data-delete')}`, { name: '' });
      toastr.success('Unit deleted');
      await load();
    }));
  }
  document.getElementById('saveUnit').addEventListener('click', save);
  document.addEventListener('DOMContentLoaded', load);
})();
</script>
}
