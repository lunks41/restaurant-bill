@{
    ViewData["Title"] = "Units";
}
<div class="app-surface mb-3 d-flex justify-content-end">
    <button type="button" class="btn-accent" id="openAddUnit">
        <i class="fas fa-plus"></i> Add Unit
    </button>
</div>

<div class="card">
    <div class="card-body-custom">
        <table id="unitsTable" class="table-custom">
            <thead>
                <tr>
                    <th>Unit Name</th>
                    <th>Code</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="unitsBody">
                <tr><td colspan="4" class="text-center text-muted">No units found.</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="unitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="unitModalTitle">Add Unit</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input id="unitId" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">Unit name</label>
                    <input id="unitName" class="form-control" placeholder="Unit name" />
                </div>
                <div>
                    <label class="form-label">Code</label>
                    <input id="unitCode" class="form-control" placeholder="Code" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveUnit">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="unitConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Inactivate</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Inactivate this unit?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmUnitInactivate">Inactivate</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const modalEl = document.getElementById('unitModal');
  if (!modalEl || !window.bootstrap) return;
  const modal = new window.bootstrap.Modal(modalEl);
  const confirmModalEl = document.getElementById('unitConfirmModal');
  const confirmModal = confirmModalEl ? new window.bootstrap.Modal(confirmModalEl) : null;
  const confirmBtn = document.getElementById('confirmUnitInactivate');
  const idEl = document.getElementById('unitId');
  const nameEl = document.getElementById('unitName');
  const codeEl = document.getElementById('unitCode');
  const titleEl = document.getElementById('unitModalTitle');
  const saveBtnEl = document.getElementById('saveUnit');
  let pendingDeleteId = null;

  const notifySafe = (message, type = 'info') => {
    if (typeof window.notify === 'function') {
      window.notify(message, type);
      return;
    }
    if (typeof toastr !== 'undefined' && typeof toastr[type] === 'function') {
      toastr[type](message);
    }
  };

  async function load() {
    const rows = await getJSON('/masters/units-data?outletId=1');
    document.getElementById('unitsBody').innerHTML = rows.length
      ? rows.map(x => `<tr><td>${x.unitName}</td><td>${x.unitCode ?? ''}</td><td>${x.isActive ? '<span class="badge-custom badge-success">Active</span>' : '<span class="badge-custom badge-muted">Inactive</span>'}</td><td><button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.unitId}" data-name="${x.unitName}" data-code="${x.unitCode ?? ''}">Edit</button><button class="btn btn-sm btn-outline-danger" data-delete="${x.unitId}">Inactivate</button></td></tr>`).join('')
      : '<tr><td colspan="4" class="text-center text-muted">No units found.</td></tr>';
    bindRowActions();
    if (window.refreshDataTableById) window.refreshDataTableById('unitsTable');
  }

  const openAdd = () => {
    idEl.value = '';
    nameEl.value = '';
    codeEl.value = '';
    titleEl.textContent = 'Add Unit';
    saveBtnEl.textContent = 'Add';
    modal.show();
  };

  const openEdit = (btn) => {
    idEl.value = btn.getAttribute('data-edit') || '';
    nameEl.value = btn.getAttribute('data-name') || '';
    codeEl.value = btn.getAttribute('data-code') || '';
    titleEl.textContent = 'Edit Unit';
    saveBtnEl.textContent = 'Update';
    modal.show();
  };

  async function save() {
    const name = nameEl.value.trim();
    if (!name) {
      notifySafe('Unit name is required', 'warning');
      return;
    }

    const id = idEl.value;
    if (id) {
      await postJSON(`/masters/units-update/${id}`, { name, code: codeEl.value.trim() });
      notifySafe('Unit updated', 'success');
    } else {
      await postJSON('/masters/units-create', { name, code: codeEl.value.trim() });
      notifySafe('Unit added', 'success');
    }
    modal.hide();
    await load();
  }

  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => openEdit(btn)));
    document.querySelectorAll('[data-delete]').forEach(btn => btn.addEventListener('click', async () => {
      pendingDeleteId = btn.getAttribute('data-delete');
      confirmModal?.show();
    }));
  }

  document.getElementById('openAddUnit')?.addEventListener('click', openAdd);
  saveBtnEl.addEventListener('click', save);
  confirmBtn?.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    await postJSON(`/masters/units-delete/${pendingDeleteId}`, { name: '' });
    notifySafe('Unit inactivated', 'success');
    confirmModal?.hide();
    pendingDeleteId = null;
    await load();
  });
  document.addEventListener('DOMContentLoaded', load);
})();
</script>
}
