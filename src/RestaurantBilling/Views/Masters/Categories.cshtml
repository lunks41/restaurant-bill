@model RestaurantBilling.Models.Masters.CategoryInputModel
@{
    var rows = (IEnumerable<Entities.Masters.Category>)ViewBag.Rows;
}
<div class="app-module-header">
    <h1 class="h3 mb-1">Masters</h1>
    <p class="app-muted mb-0">Manage core menu and taxation setup.</p>
</div>

<nav class="nav app-module-tabs gap-2">
    <a class="nav-link active" asp-controller="Masters" asp-action="Categories">Categories</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Items">Items</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Tables">Tables</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Customers">Customers</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Suppliers">Suppliers</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Taxes">Taxes</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Units">Units</a>
    <a class="nav-link" asp-controller="Masters" asp-action="Printers">Printers</a>
</nav>

<div class="app-surface mb-3">
<form method="post" class="row g-2">
    @Html.AntiForgeryToken()
    <input asp-for="CategoryId" type="hidden" />
    <div class="col-md-5">
        <input asp-for="CategoryName" class="form-control" placeholder="Category name" />
    </div>
    <div class="col-md-2">
        <input asp-for="SortOrder" class="form-control" placeholder="Sort order" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary">@(Model.CategoryId.HasValue ? "Update" : "Add")</button>
        @if (Model.CategoryId.HasValue)
        {
            <a class="btn btn-outline-secondary" href="/masters/categories">Cancel</a>
        }
    </div>
</form>
</div>

<div class="app-surface">
<table class="table table-sm app-table mb-0">
    <thead>
    <tr><th>Name</th><th>Sort</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var row in rows)
    {
        <tr>
            <td>@row.CategoryName</td>
            <td>@row.SortOrder</td>
            <td class="d-flex gap-2">
                <a class="btn btn-sm btn-outline-primary" href="/masters/categories?editId=@row.CategoryId">Edit</a>
                <form method="post" action="/masters/categories/@row.CategoryId/delete">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
