@model RestaurantBilling.Models.Masters.CategoryInputModel
@{
    var rows = (IEnumerable<Entities.Masters.Category>)ViewBag.Rows;
}

<partial name="_MastersCoreTabs" />

<div class="app-surface mb-3 d-flex justify-content-end">
    <button type="button" class="btn-accent" id="openAddCategory">
        <i class="fas fa-plus"></i> Add Category
    </button>
</div>

<div class="card">
    <div class="card-body-custom">
    <table id="categoriesTable" class="table-custom">
        <thead>
            <tr>
                <th>Name</th>
                <th>Sort</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in rows)
            {
                <tr>
                    <td>@row.CategoryName</td>
                    <td>@row.SortOrder</td>
                    <td>
                        @if (row.IsActive)
                        {
                            <span class="badge-custom badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge-custom badge-muted">Inactive</span>
                        }
                    </td>
                    <td class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-primary btn-edit-category"
                                data-id="@row.CategoryId"
                                data-name="@row.CategoryName"
                                data-sort="@row.SortOrder"
                                data-is-active="@row.IsActive.ToString().ToLowerInvariant()">
                            Edit
                        </button>
                        <form method="post" action="/masters/categories/@row.CategoryId/delete" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger btn-delete-category">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" id="categoryForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="categoryModalTitle">Add Category</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input asp-for="CategoryId" type="hidden" id="modalCategoryId" />
                    <div class="mb-3">
                        <label class="form-label">Category name</label>
                        <input asp-for="CategoryName" class="form-control" id="modalCategoryName" placeholder="Category name" required />
                    </div>
                    <div>
                        <label class="form-label">Sort order</label>
                        <input asp-for="SortOrder" class="form-control" id="modalSortOrder" placeholder="Sort order" />
                    </div>
                    <div class="mt-3">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" id="modalCategoryIsActive" />
                            <label class="form-check-label" for="modalCategoryIsActive">Is Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="saveCategoryBtn">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const modalEl = document.getElementById('categoryModal');
  if (!modalEl || !window.bootstrap) return;

  const modal = new window.bootstrap.Modal(modalEl);
  const titleEl = document.getElementById('categoryModalTitle');
  const idEl = document.getElementById('modalCategoryId');
  const nameEl = document.getElementById('modalCategoryName');
  const sortEl = document.getElementById('modalSortOrder');
  const isActiveEl = document.getElementById('modalCategoryIsActive');
  const saveBtn = document.getElementById('saveCategoryBtn');

  const openAdd = () => {
    titleEl.textContent = 'Add Category';
    saveBtn.textContent = 'Add';
    idEl.value = '';
    nameEl.value = '';
    sortEl.value = '0';
    isActiveEl.checked = true;
    modal.show();
  };

  const openEdit = (btn) => {
    titleEl.textContent = 'Edit Category';
    saveBtn.textContent = 'Update';
    idEl.value = btn.getAttribute('data-id') || '';
    nameEl.value = btn.getAttribute('data-name') || '';
    sortEl.value = btn.getAttribute('data-sort') || '0';
    isActiveEl.checked = (btn.getAttribute('data-is-active') !== 'false');
    modal.show();
  };

  document.getElementById('openAddCategory')?.addEventListener('click', openAdd);
  document.querySelectorAll('.btn-edit-category').forEach((btn) => {
    btn.addEventListener('click', () => openEdit(btn));
  });
  document.querySelectorAll('.btn-delete-category').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const deleteForm = btn.closest('form');
      if (!deleteForm) return;
      confirmAction('Delete this category? It will be marked as inactive.', () => deleteForm.submit());
    });
  });
})();
</script>
}
