<div class="app-module-header">
    <h1 class="h3 mb-1">Day Close</h1>
    <p class="app-muted mb-0">X/Z report checks and business date lock process.</p>
</div>
<div class="card mb-3">
    <div class="card-body-custom">
        <div class="row g-2">
            <div class="col-md-3"><label class="form-label-custom">Business Date</label><input id="businessDate" type="date" class="form-control-custom" /></div>
            <div class="col-md-3"><label class="form-label-custom">Opening Cash</label><input id="openingCash" type="number" step="0.01" class="form-control-custom" /></div>
            <div class="col-md-3"><label class="form-label-custom">Closing Cash</label><input id="closingCash" type="number" step="0.01" class="form-control-custom" /></div>
            <div class="col-md-3 d-flex align-items-end"><button id="previewClose" class="btn-ghost">Preview</button>&nbsp;<button id="finalizeClose" class="btn-accent">Finalize</button></div>
        </div>
    </div>
</div>
<div class="card">
    <div class="card-body-custom" id="dayCloseResult">Run preview to view daily settlement totals.</div>
</div>

@section Scripts {
<script>
(() => {
  const today = new Date().toISOString().slice(0, 10);
  document.getElementById('businessDate').value = today;

  async function preview() {
    const result = await postJSON('/dayclose/preview', {
      outletId: 1,
      businessDate: document.getElementById('businessDate').value
    });
    document.getElementById('dayCloseResult').innerHTML = `
      <div>Unsettled Bills: <b>${result.unsettledBills}</b></div>
      <div>Total Sales: <b>${fmtINR(result.totalSales)}</b></div>
      <div>Total Tax: <b>${fmtINR(result.totalTax)}</b></div>`;
  }

  async function finalizeClose() {
    const result = await postJSON('/dayclose/finalize', {
      outletId: 1,
      businessDate: document.getElementById('businessDate').value,
      closedBy: 1,
      openingCash: parseFloat(document.getElementById('openingCash').value || '0'),
      closingCash: parseFloat(document.getElementById('closingCash').value || '0')
    });
    toastr.success(`Day closed. Next date: ${result.nextBusinessDate}`);
  }

  document.getElementById('previewClose').addEventListener('click', preview);
  document.getElementById('finalizeClose').addEventListener('click', finalizeClose);
})();
</script>
}
