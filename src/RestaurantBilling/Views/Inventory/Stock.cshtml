@{
    if ((ViewData["EmbedMode"] as bool?) == true)
    {
        Layout = null;
    }
    ViewData["Title"] = "Grocery Stock";
}

<div class="app-module-header">
    <h1 class="h3 mb-1">Grocery Stock</h1>
    <p class="app-muted mb-0">Maintain only grocery and kitchen consumable stock items.</p>
</div>

<div class="app-surface mb-3 d-flex flex-wrap align-items-end gap-2">
    <div style="min-width:220px;">
        <label class="form-label mb-1">Search</label>
        <input id="stockSearch" class="form-control" placeholder="Grocery name" />
    </div>
    <div style="min-width:180px;">
        <label class="form-label mb-1">Unit filter</label>
        <select id="stockUnitFilter" class="form-select">
            <option value="">All units</option>
        </select>
    </div>
    <button type="button" class="btn btn-outline-secondary" id="exportStockItems">
        <i class="fas fa-file-csv"></i> Export CSV
    </button>
    <button type="button" class="btn-accent ms-auto" id="openAddStockItem">
        <i class="fas fa-plus"></i> Add Grocery Stock
    </button>
</div>

<div class="card">
    <div class="card-body-custom">
        <table id="stockItemsTable" class="table-custom">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Unit</th>
                    <th>Rate</th>
                    <th>Current Qty</th>
                    <th>Reorder</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="stockItemsBody">
                <tr>
                    <td class="text-center text-muted">No stock items found.</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="stockItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="stockItemModalTitle">Add Grocery Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input id="stockItemId" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">Grocery Item</label>
                    <select id="stockName" class="form-select">
                        <option value="">Select grocery item</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Unit</label>
                    <select id="stockUnitId" class="form-select">
                        <option value="">Select unit</option>
                    </select>
                </div>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Purchase rate</label>
                        <input id="stockRate" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Current qty</label>
                        <input id="stockCurrentQty" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Reorder</label>
                        <input id="stockReorder" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveStockItem">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const modalEl = document.getElementById('stockItemModal');
  if (!modalEl || !window.bootstrap) return;
  const modal = new window.bootstrap.Modal(modalEl);

  const idEl = document.getElementById('stockItemId');
  const nameEl = document.getElementById('stockName');
  const unitEl = document.getElementById('stockUnitId');
  const rateEl = document.getElementById('stockRate');
  const currentQtyEl = document.getElementById('stockCurrentQty');
  const reorderEl = document.getElementById('stockReorder');
  const searchEl = document.getElementById('stockSearch');
  const unitFilterEl = document.getElementById('stockUnitFilter');
  const titleEl = document.getElementById('stockItemModalTitle');
  const saveBtnEl = document.getElementById('saveStockItem');
  let currentPage = 1;
  const pageSize = 1000;

  const notifySafe = (message, type = 'info') => {
    if (typeof window.notify === 'function') {
      window.notify(message, type);
      return;
    }
    if (typeof toastr !== 'undefined' && typeof toastr[type] === 'function') {
      toastr[type](message);
    }
  };

  async function loadUnits() {
    const rows = await getJSON(`/master/stock-units-data?outletId=1&_=${Date.now()}`);
    unitEl.innerHTML = '<option value="">Select unit</option>' + rows.map(u => `<option value="${u.unitId}">${u.unitName} (${u.unitCode})</option>`).join('');
    unitFilterEl.innerHTML = '<option value="">All units</option>' + rows.map(u => `<option value="${u.unitId}">${u.unitName} (${u.unitCode})</option>`).join('');
  }

  async function loadGroceries() {
    const rows = await getJSON('/master/grocery-options');
    nameEl.innerHTML = '<option value="">Select grocery item</option>' + rows.map(n => `<option value="${n}">${n}</option>`).join('');
  }

  async function loadItems(resetPage = false) {
    if (resetPage) currentPage = 1;
    if (window.jQuery && jQuery.fn.DataTable) {
      const table = jQuery('#stockItemsTable');
      if (jQuery.fn.dataTable.isDataTable(table)) {
        table.DataTable().destroy();
      }
    }
    const q = new URLSearchParams({ outletId: '1' });
    if (searchEl.value.trim()) q.set('search', searchEl.value.trim());
    if (unitFilterEl.value) q.set('unitId', unitFilterEl.value);
    q.set('page', String(currentPage));
    q.set('pageSize', String(pageSize));
    q.set('_', Date.now().toString());
    const result = await getJSON(`/master/stock-items-data?${q.toString()}`);
    const rows = Array.isArray(result) ? result : (result.items || []);
    if (!Array.isArray(result)) {
      currentPage = result.page || 1;
    }
    document.getElementById('stockItemsBody').innerHTML = rows.length
      ? rows.map(x => `<tr><td>${x.itemCode || ''}</td><td>${x.itemName}</td><td>${x.unitName || '-'}</td><td>${x.purchasePrice ?? 0}</td><td>${x.currentQty ?? 0}</td><td>${x.reorderLevel ?? 0}</td><td>${x.isActive ? '<span class="badge-custom badge-success">Active</span>' : '<span class="badge-custom badge-muted">Inactive</span>'}</td><td><button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.itemId}" data-name="${x.itemName}" data-unit-id="${x.unitId || ''}" data-rate="${x.purchasePrice ?? 0}" data-current-qty="${x.currentQty ?? 0}" data-reorder="${x.reorderLevel ?? 0}">Edit</button><button class="btn btn-sm btn-outline-danger" data-delete="${x.itemId}">Delete</button></td></tr>`).join('')
      : `<tr>
           <td class="text-center text-muted">No stock items found.</td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
         </tr>`;
    bindRowActions();
    if (window.refreshDataTableById) window.refreshDataTableById('stockItemsTable');
  }

  const openAdd = async () => {
    await loadUnits();
    await loadGroceries();
    idEl.value = '';
    nameEl.value = '';
    unitEl.value = '';
    rateEl.value = '0';
    currentQtyEl.value = '0';
    reorderEl.value = '0';
    titleEl.textContent = 'Add Grocery Stock';
    saveBtnEl.textContent = 'Add';
    modal.show();
  };

  const openEdit = async (btn) => {
    await loadUnits();
    await loadGroceries();
    idEl.value = btn.getAttribute('data-edit') || '';
    nameEl.value = btn.getAttribute('data-name') || '';
    unitEl.value = btn.getAttribute('data-unit-id') || '';
    rateEl.value = btn.getAttribute('data-rate') || '0';
    currentQtyEl.value = btn.getAttribute('data-current-qty') || '0';
    reorderEl.value = btn.getAttribute('data-reorder') || '0';
    titleEl.textContent = 'Edit Grocery Stock';
    saveBtnEl.textContent = 'Update';
    modal.show();
  };

  async function save() {
    const name = nameEl.value.trim();
    if (!name) {
      notifySafe('Please select grocery item', 'warning');
      return;
    }

    const payload = {
      outletId: 1,
      name,
      unitId: unitEl.value ? parseInt(unitEl.value, 10) : null,
      purchasePrice: parseFloat(rateEl.value || '0'),
      currentQty: parseFloat(currentQtyEl.value || '0'),
      reorderLevel: parseFloat(reorderEl.value || '0')
    };

    try {
      const id = idEl.value;
      if (id) {
        await postJSON(`/master/stock-items-update/${id}`, payload);
        notifySafe('Grocery stock updated', 'success');
      } else {
        await postJSON('/master/stock-items-create', payload);
        notifySafe('Grocery stock added', 'success');
      }
      modal.hide();
      await loadItems();
    } catch (_) {
      notifySafe('Unable to save grocery stock right now', 'error');
    }
  }

  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => openEdit(btn)));
    document.querySelectorAll('[data-delete]').forEach(btn => btn.addEventListener('click', async () => {
      if (!confirm('Delete this grocery stock item?')) return;
      try {
        await postJSON(`/master/stock-items-delete/${btn.getAttribute('data-delete')}`, {});
        notifySafe('Grocery stock deleted', 'success');
        await loadItems();
      } catch (_) {
        notifySafe('Unable to delete grocery stock right now', 'error');
      }
    }));
  }

  document.getElementById('openAddStockItem')?.addEventListener('click', openAdd);
  saveBtnEl.addEventListener('click', save);
  searchEl.addEventListener('input', () => loadItems(true));
  unitFilterEl.addEventListener('change', () => loadItems(true));
  document.getElementById('exportStockItems')?.addEventListener('click', () => {
    const q = new URLSearchParams({ outletId: '1' });
    if (searchEl.value.trim()) q.set('search', searchEl.value.trim());
    if (unitFilterEl.value) q.set('unitId', unitFilterEl.value);
    window.location.href = `/master/stock-items-export?${q.toString()}`;
  });
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', async () => {
      await loadUnits();
      await loadGroceries();
      await loadItems();
    });
  } else {
    Promise.all([loadUnits(), loadGroceries()]).then(() => loadItems());
  }
})();
</script>
}
