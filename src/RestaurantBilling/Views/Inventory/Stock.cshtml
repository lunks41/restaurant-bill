@{
    ViewData["Title"] = "Inventory";
}

@section Styles {
<style>
  /* Inventory table layout */
  #stockItemsTable {
    table-layout: fixed;
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  #stockItemsTable th,
  #stockItemsTable td {
    padding: 9px 10px;
    font-size: 12.5px;
    line-height: 1.25;
    white-space: nowrap;
    vertical-align: middle;
  }

  #stockItemsTable th:nth-child(1),
  #stockItemsTable td:nth-child(1) { width: 72px; }   /* Code */
  #stockItemsTable th:nth-child(2),
  #stockItemsTable td:nth-child(2) { width: 180px; }  /* Name */
  #stockItemsTable th:nth-child(3),
  #stockItemsTable td:nth-child(3) { width: 90px; }   /* Unit */
  #stockItemsTable th:nth-child(4),
  #stockItemsTable td:nth-child(4) { width: 95px; text-align: right; }   /* Opening */
  #stockItemsTable th:nth-child(5),
  #stockItemsTable td:nth-child(5) { width: 95px; text-align: right; }   /* Purchased */
  #stockItemsTable th:nth-child(6),
  #stockItemsTable td:nth-child(6) { width: 95px; text-align: right; }   /* Sold */
  #stockItemsTable th:nth-child(7),
  #stockItemsTable td:nth-child(7) { width: 95px; text-align: right; }   /* Disposed */
  #stockItemsTable th:nth-child(8),
  #stockItemsTable td:nth-child(8) { width: 95px; text-align: right; }   /* Closing */
  #stockItemsTable th:nth-child(9),
  #stockItemsTable td:nth-child(9) { width: 90px; }   /* Status */
  #stockItemsTable th:nth-child(10),
  #stockItemsTable td:nth-child(10) { width: 90px; text-align: right; } /* Action */

  #stockItemsTable td:nth-child(2) {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #stockItemsTable .btn.btn-sm {
    min-height: 28px;
    height: 28px;
    padding: 0 9px;
    font-size: 11px;
    line-height: 1;
    border-radius: 7px;
  }

  #stockItemsTable .badge-custom {
    font-size: 10px;
    padding: 2px 7px;
  }

  #stockItemsTable thead th {
    font-size: 11px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  #stockItemsTable td:last-child {
    white-space: nowrap;
  }

  #stockItemsTable tbody tr:hover {
    background: color-mix(in srgb, var(--bg-surface) 82%, #ffffff 18%);
  }

  #stockItemsTable_wrapper .dataTables_filter input,
  #stockItemsTable_wrapper .dataTables_length select {
    min-height: 32px;
    height: 32px;
    font-size: 12px;
  }

  @@media (max-width: 1199px) {
    #stockItemsTable th,
    #stockItemsTable td {
      padding: 6px 8px;
      font-size: 11.5px;
    }
  }
</style>
}

<div class="app-surface mb-3 d-flex flex-wrap align-items-end gap-2 stock-compact-controls">
    <div style="min-width:220px;">
        <label class="form-label mb-1">Search</label>
        <input id="stockSearch" class="form-control" placeholder="Item name" />
    </div>
    <div style="min-width:180px;">
        <label class="form-label mb-1">Unit filter</label>
        <select id="stockUnitFilter" class="form-select">
            <option value="">All units</option>
        </select>
    </div>
    <button type="button" class="btn btn-outline-secondary" id="exportStockItems">
        <i class="fas fa-file-excel"></i> Export Excel
    </button>
    <button type="button" class="btn-accent ms-auto" id="openAddStockItem">
        <i class="fas fa-plus"></i> Add Item Stock
    </button>
</div>

<div class="app-surface mb-3 d-flex flex-wrap gap-3 small" id="stockSummaryBar">
    <span><strong>Date:</strong> <span id="sumDate">-</span></span>
    <span><strong>Items:</strong> <span id="sumItems">0</span></span>
    <span><strong>Opening:</strong> <span id="sumOpening">0.00</span></span>
    <span><strong>Purchased:</strong> <span id="sumPurchased">0.00</span></span>
    <span><strong>Sold:</strong> <span id="sumSold">0.00</span></span>
    <span><strong>Disposed:</strong> <span id="sumDisposed">0.00</span></span>
    <span><strong>Closing:</strong> <span id="sumClosing">0.00</span></span>
</div>

<div class="card stock-compact">
    <div class="card-body-custom stock-compact-table-wrap">
        <table id="stockItemsTable" class="table-custom">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Unit</th>
                    <th>Opening</th>
                    <th>Purchased</th>
                    <th>Sold</th>
                    <th>Disposed</th>
                    <th>Closing</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="stockItemsBody">
                <tr>
                    <td class="text-center text-muted">No stock items found.</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="stockItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="stockItemModalTitle">Add Item Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input id="stockItemId" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">Item</label>
                    <select id="stockItemRefId" class="form-select">
                        <option value="">Select item</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Unit</label>
                    <select id="stockUnitId" class="form-select">
                        <option value="">Select unit</option>
                    </select>
                </div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">Opening qty</label>
                        <input id="stockOpeningQty" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Purchased qty</label>
                        <input id="stockPurchasedQty" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
                <div class="row g-2 mt-1">
                    <div class="col-md-6">
                        <label class="form-label">Disposed qty</label>
                        <input id="stockDisposedQty" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Sold qty (auto)</label>
                        <input id="stockSoldQty" type="number" step="0.01" class="form-control" readonly />
                    </div>
                </div>
                <div class="row g-2 mt-1">
                    <div class="col-md-6">
                        <label class="form-label">Closing qty</label>
                        <input id="stockClosingQty" type="number" step="0.01" class="form-control" readonly />
                    </div>
                </div>
                <div class="row g-2 mt-1">
                    <div class="col-md-6">
                        <label class="form-label">Stock date</label>
                        <input id="stockStockDate" type="date" class="form-control" />
                    </div>
                </div>
                <div class="mt-2 small text-muted">
                    Closing formula: Opening + Purchased - Sold - Disposed
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveStockItem">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const apiPrefix = '@(ViewData["ApiPrefix"] as string ?? "/inventory")';
  const modalEl = document.getElementById('stockItemModal');
  if (!modalEl || !window.bootstrap) return;
  const modal = new window.bootstrap.Modal(modalEl);

  const idEl = document.getElementById('stockItemId');
  const itemEl = document.getElementById('stockItemRefId');
  const unitEl = document.getElementById('stockUnitId');
  const openingQtyEl = document.getElementById('stockOpeningQty');
  const purchasedQtyEl = document.getElementById('stockPurchasedQty');
  const soldQtyEl = document.getElementById('stockSoldQty');
  const disposedQtyEl = document.getElementById('stockDisposedQty');
  const closingQtyEl = document.getElementById('stockClosingQty');
  const stockDateEl = document.getElementById('stockStockDate');
  const searchEl = document.getElementById('stockSearch');
  const unitFilterEl = document.getElementById('stockUnitFilter');
  const titleEl = document.getElementById('stockItemModalTitle');
  const saveBtnEl = document.getElementById('saveStockItem');
  const sumDateEl = document.getElementById('sumDate');
  const sumItemsEl = document.getElementById('sumItems');
  const sumOpeningEl = document.getElementById('sumOpening');
  const sumPurchasedEl = document.getElementById('sumPurchased');
  const sumSoldEl = document.getElementById('sumSold');
  const sumDisposedEl = document.getElementById('sumDisposed');
  const sumClosingEl = document.getElementById('sumClosing');
  let currentPage = 1;
  const pageSize = 1000;

  const notifySafe = (message, type = 'info') => {
    if (typeof window.notify === 'function') {
      window.notify(message, type);
      return;
    }
    if (typeof toastr !== 'undefined' && typeof toastr[type] === 'function') {
      toastr[type](message);
    }
  };

  const todayIso = () => {
    const d = new Date();
    const tzAdjusted = new Date(d.getTime() - (d.getTimezoneOffset() * 60000));
    return tzAdjusted.toISOString().slice(0, 10);
  };

  const recalcClosing = () => {
    const opening = parseFloat(openingQtyEl.value || '0');
    const purchased = parseFloat(purchasedQtyEl.value || '0');
    const sold = parseFloat(soldQtyEl.value || '0');
    const disposed = parseFloat(disposedQtyEl.value || '0');
    closingQtyEl.value = (opening + purchased - sold - disposed).toFixed(2);
  };

  const fmt2 = (value) => Number(value ?? 0).toFixed(2);

  async function loadSummary() {
    const result = await getJSON(`${apiPrefix}/stock-summary?_=${Date.now()}`);
    sumDateEl.textContent = result.stockDate || '-';
    sumItemsEl.textContent = String(result.items ?? 0);
    sumOpeningEl.textContent = fmt2(result.openingQty);
    sumPurchasedEl.textContent = fmt2(result.purchasedQty);
    sumSoldEl.textContent = fmt2(result.soldQty);
    sumDisposedEl.textContent = fmt2(result.disposedQty);
    sumClosingEl.textContent = fmt2(result.closingQty);
  }

  async function loadUnits() {
    const rows = await getJSON(`${apiPrefix}/stock-units-data?outletId=1&_=${Date.now()}`);
    unitEl.innerHTML = '<option value="">Select unit</option>' + rows.map(u => `<option value="${u.unitId}">${u.unitName} (${u.unitCode})</option>`).join('');
    unitFilterEl.innerHTML = '<option value="">All units</option>' + rows.map(u => `<option value="${u.unitId}">${u.unitName} (${u.unitCode})</option>`).join('');
  }

  async function loadItemsCatalog() {
    const rows = await getJSON(`${apiPrefix}/item-options?_=${Date.now()}`);
    itemEl.innerHTML = '<option value="">Select item</option>' + rows.map(g => `<option value="${g.itemId}">${g.itemName}</option>`).join('');
  }

  async function loadItems(resetPage = false) {
    if (resetPage) currentPage = 1;
    if (window.jQuery && jQuery.fn.DataTable) {
      const table = jQuery('#stockItemsTable');
      if (jQuery.fn.dataTable.isDataTable(table)) {
        table.DataTable().destroy();
      }
    }
    const q = new URLSearchParams({ outletId: '1' });
    if (searchEl.value.trim()) q.set('search', searchEl.value.trim());
    if (unitFilterEl.value) q.set('unitId', unitFilterEl.value);
    q.set('page', String(currentPage));
    q.set('pageSize', String(pageSize));
    q.set('_', Date.now().toString());
    const result = await getJSON(`${apiPrefix}/stock-items-data?${q.toString()}`);
    const rows = Array.isArray(result) ? result : (result.items || []);
    if (!Array.isArray(result)) {
      currentPage = result.page || 1;
    }
    document.getElementById('stockItemsBody').innerHTML = rows.length
      ? rows.map(x => `<tr><td>${x.itemCode || ''}</td><td>${x.itemName}</td><td>${x.unitName || '-'}</td><td>${Number(x.openingQty ?? 0).toFixed(2)}</td><td>${Number(x.purchasedQty ?? 0).toFixed(2)}</td><td>${Number(x.soldQty ?? 0).toFixed(2)}</td><td>${Number(x.disposedQty ?? 0).toFixed(2)}</td><td>${Number(x.closingQty ?? 0).toFixed(2)}</td><td>${x.isActive ? '<span class="badge-custom badge-success">Active</span>' : '<span class="badge-custom badge-muted">Inactive</span>'}</td><td><button class="btn btn-sm btn-outline-primary" data-edit="${x.itemId}" data-item-id="${x.itemIdRef || ''}" data-unit-id="${x.unitId || ''}" data-opening-qty="${x.openingQty ?? 0}" data-purchased-qty="${x.purchasedQty ?? 0}" data-sold-qty="${x.soldQty ?? 0}" data-disposed-qty="${x.disposedQty ?? 0}" data-closing-qty="${x.closingQty ?? 0}" data-stock-date="${String(x.stockDate ?? '').slice(0,10)}">Edit</button></td></tr>`).join('')
      : `<tr>
           <td class="text-center text-muted">No stock items found.</td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
           <td></td>
         </tr>`;
    bindRowActions();
    if (window.refreshDataTableById) window.refreshDataTableById('stockItemsTable');
  }

  const openAdd = async () => {
    await loadUnits();
    await loadItemsCatalog();
    idEl.value = '';
    itemEl.value = '';
    unitEl.value = '';
    openingQtyEl.value = '0';
    purchasedQtyEl.value = '0';
    soldQtyEl.value = '0';
    disposedQtyEl.value = '0';
    closingQtyEl.value = '0.00';
    stockDateEl.value = todayIso();
    recalcClosing();
    titleEl.textContent = 'Add Item Stock';
    saveBtnEl.textContent = 'Add';
    modal.show();
  };

  const openEdit = async (btn) => {
    await loadUnits();
    await loadItemsCatalog();
    idEl.value = btn.getAttribute('data-edit') || '';
    itemEl.value = btn.getAttribute('data-item-id') || '';
    unitEl.value = btn.getAttribute('data-unit-id') || '';
    openingQtyEl.value = btn.getAttribute('data-opening-qty') || '0';
    purchasedQtyEl.value = btn.getAttribute('data-purchased-qty') || '0';
    soldQtyEl.value = btn.getAttribute('data-sold-qty') || '0';
    disposedQtyEl.value = btn.getAttribute('data-disposed-qty') || '0';
    closingQtyEl.value = btn.getAttribute('data-closing-qty') || '0';
    stockDateEl.value = btn.getAttribute('data-stock-date') || todayIso();
    recalcClosing();
    titleEl.textContent = 'Edit Item Stock';
    saveBtnEl.textContent = 'Update';
    modal.show();
  };

  async function save() {
    if (!itemEl.value) {
      notifySafe('Please select item', 'warning');
      return;
    }

    const payload = {
      outletId: 1,
      itemId: parseInt(itemEl.value, 10),
      unitId: unitEl.value ? parseInt(unitEl.value, 10) : null,
      openingQty: parseFloat(openingQtyEl.value || '0'),
      purchasedQty: parseFloat(purchasedQtyEl.value || '0'),
      soldQty: parseFloat(soldQtyEl.value || '0'),
      disposedQty: parseFloat(disposedQtyEl.value || '0'),
      type: 'snapshot',
      stockDate: stockDateEl.value
    };

    try {
      const id = idEl.value;
      if (id) {
        await postJSON(`${apiPrefix}/stock-items-update/${id}`, payload);
        notifySafe('Item stock updated', 'success');
      } else {
        await postJSON(`${apiPrefix}/stock-items-create`, payload);
        notifySafe('Item stock added', 'success');
      }
      modal.hide();
      await loadItems();
      await loadSummary();
    } catch (_) {
      notifySafe('Unable to save item stock right now', 'error');
    }
  }

  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => openEdit(btn)));
  }

  document.getElementById('openAddStockItem')?.addEventListener('click', openAdd);
  saveBtnEl.addEventListener('click', save);
  searchEl.addEventListener('input', () => loadItems(true));
  unitFilterEl.addEventListener('change', () => loadItems(true));
  [openingQtyEl, purchasedQtyEl, disposedQtyEl].forEach(el => el.addEventListener('input', recalcClosing));
  document.getElementById('exportStockItems')?.addEventListener('click', () => {
    const q = new URLSearchParams({ outletId: '1' });
    if (searchEl.value.trim()) q.set('search', searchEl.value.trim());
    if (unitFilterEl.value) q.set('unitId', unitFilterEl.value);
    q.set('format', 'xlsx');
    window.location.href = `${apiPrefix}/stock-items-export?${q.toString()}`;
  });
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', async () => {
      await loadUnits();
      await loadItemsCatalog();
      await loadItems();
      await loadSummary();
    });
  } else {
    Promise.all([loadUnits(), loadItemsCatalog()]).then(async () => {
      await loadItems();
      await loadSummary();
    });
  }
})();
</script>
}
