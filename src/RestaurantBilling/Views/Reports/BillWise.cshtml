@{ ViewData["Title"] = "Bill Wise"; }
<div class="page-header"><div><h1 class="page-title-h">Bill Wise Report</h1><div class="page-sub">Invoice-level transaction list.</div></div></div>
<div class="filter-bar"><div><label class="form-label-custom">From</label><input id="fromDate" type="date" class="form-control-custom"/></div><div><label class="form-label-custom">To</label><input id="toDate" type="date" class="form-control-custom"/></div><button id="runBillWise" class="btn-accent">Run</button><button id="exportBillCsv" class="btn-ghost"><i class="fas fa-file-csv"></i> CSV</button><button id="exportBillXlsx" class="btn-ghost" style="color:var(--success);"><i class="fas fa-file-excel"></i> Excel</button></div>
<div class="card"><div class="card-body-custom"><table class="table-custom"><thead><tr><th>Bill No</th><th>Date</th><th>Status</th><th>Total</th></tr></thead><tbody id="billWiseBody"><tr><td colspan="4" class="text-center text-muted">No data</td></tr></tbody></table></div></div>

@section Scripts {
<script>
(() => {
  const today = new Date();
  const from = new Date(today);
  from.setDate(today.getDate() - 6);
  const fmt = d => d.toISOString().slice(0, 10);
  document.getElementById('fromDate').value = fmt(from);
  document.getElementById('toDate').value = fmt(today);

  async function run() {
    const fromDate = document.getElementById('fromDate').value;
    const toDate = document.getElementById('toDate').value;
    const rows = await getJSON(`/reports/bill-wise?outletId=1&from=${fromDate}&to=${toDate}`);
    document.getElementById('billWiseBody').innerHTML = rows.length
      ? rows.map(x => `<tr><td>${x.billNo}</td><td>${x.billDate}</td><td>${x.status}</td><td>${fmtINR(x.grandTotal)}</td></tr>`).join('')
      : '<tr><td colspan="4" class="text-center text-muted">No data</td></tr>';
  }

  document.getElementById('runBillWise').addEventListener('click', run);
  document.getElementById('exportBillCsv').addEventListener('click', () =>
    window.open(`/reports/bill-wise-export?outletId=1&from=${document.getElementById('fromDate').value}&to=${document.getElementById('toDate').value}&format=csv`, '_blank'));
  document.getElementById('exportBillXlsx').addEventListener('click', () =>
    window.open(`/reports/bill-wise-export?outletId=1&from=${document.getElementById('fromDate').value}&to=${document.getElementById('toDate').value}&format=xlsx`, '_blank'));
  document.addEventListener('DOMContentLoaded', run);
})();
</script>
}
