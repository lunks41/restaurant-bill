@{ ViewData["Title"] = "Stock Report"; }
<div class="page-header"><div><h1 class="page-title-h">Stock Report</h1><div class="page-sub">Movement and current stock balances.</div></div></div>
<div class="filter-bar"><div><label class="form-label-custom">From</label><input id="fromDate" type="date" class="form-control-custom"/></div><div><label class="form-label-custom">To</label><input id="toDate" type="date" class="form-control-custom"/></div><button id="runStockReport" class="btn-accent">Run</button><button id="exportStockCsv" class="btn-ghost"><i class="fas fa-file-csv"></i> CSV</button><button id="exportStockXlsx" class="btn-ghost" style="color:var(--success);"><i class="fas fa-file-excel"></i> Excel</button></div>
<div class="card"><div class="card-body-custom"><table class="table-custom"><thead><tr><th>Date</th><th>Item</th><th>In Qty</th><th>Out Qty</th><th>Balance</th><th>Ref</th></tr></thead><tbody id="stockReportBody"><tr><td colspan="6" class="text-center text-muted">No data</td></tr></tbody></table></div></div>

@section Scripts {
<script>
(() => {
  const today = new Date();
  const from = new Date(today);
  from.setDate(today.getDate() - 6);
  const fmt = d => d.toISOString().slice(0, 10);
  document.getElementById('fromDate').value = fmt(from);
  document.getElementById('toDate').value = fmt(today);

  async function run() {
    const fromDate = document.getElementById('fromDate').value;
    const toDate = document.getElementById('toDate').value;
    const rows = await getJSON(`/reports/stock-movement?outletId=1&from=${fromDate}&to=${toDate}`);
    document.getElementById('stockReportBody').innerHTML = rows.length
      ? rows.map(x => `<tr><td>${x.businessDate}</td><td>${x.itemName}</td><td>${x.inQty}</td><td>${x.outQty}</td><td>${x.runningBalance}</td><td>${x.referenceType}</td></tr>`).join('')
      : '<tr><td colspan="6" class="text-center text-muted">No data</td></tr>';
  }

  document.getElementById('runStockReport').addEventListener('click', run);
  document.getElementById('exportStockCsv').addEventListener('click', () =>
    window.open(`/reports/stock-movement-export?outletId=1&from=${document.getElementById('fromDate').value}&to=${document.getElementById('toDate').value}&format=csv`, '_blank'));
  document.getElementById('exportStockXlsx').addEventListener('click', () =>
    window.open(`/reports/stock-movement-export?outletId=1&from=${document.getElementById('fromDate').value}&to=${document.getElementById('toDate').value}&format=xlsx`, '_blank'));
  document.addEventListener('DOMContentLoaded', run);
})();
</script>
}
