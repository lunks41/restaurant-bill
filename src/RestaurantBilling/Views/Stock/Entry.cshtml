<div class="app-module-header">
    <h1 class="h3 mb-1">Stock</h1>
    <p class="app-muted mb-0">Inventory movements, losses, and physical stock checks.</p>
</div>
<nav class="nav app-module-tabs gap-2">
    <a class="nav-link active" asp-controller="Stock" asp-action="Entry">Entry</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Adjustment">Adjustment</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Loss">Loss</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Take">Stock Take</a>
</nav>

<div class="card mb-3">
    <div class="card-body-custom">
        <div class="row g-2">
            <div class="col-md-4"><label class="form-label-custom">Item</label><select id="itemId" class="form-select-custom"></select></div>
            <div class="col-md-2"><label class="form-label-custom">Qty</label><input id="qty" type="number" step="0.001" class="form-control-custom" /></div>
            <div class="col-md-2"><label class="form-label-custom">Rate</label><input id="rate" type="number" step="0.01" class="form-control-custom" /></div>
            <div class="col-md-2"><label class="form-label-custom">Business Date</label><input id="businessDate" type="date" class="form-control-custom" /></div>
            <div class="col-md-2"><label class="form-label-custom">Expiry</label><input id="expiryOn" type="date" class="form-control-custom" /></div>
        </div>
        <div class="mt-3">
            <button class="btn-accent" id="saveEntry">Save Entry</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const today = new Date().toISOString().slice(0, 10);
  document.getElementById('businessDate').value = today;

  async function loadItems() {
    const rows = await getJSON('/stock/items?outletId=1');
    const options = ['<option value="">Select item</option>']
      .concat(rows.map(x => `<option value="${x.itemId}">${x.itemName}</option>`));
    document.getElementById('itemId').innerHTML = options.join('');
  }

  async function save() {
    const payload = {
      outletId: 1,
      itemId: parseInt(document.getElementById('itemId').value, 10),
      qty: parseFloat(document.getElementById('qty').value || '0'),
      costPerUnit: parseFloat(document.getElementById('rate').value || '0'),
      businessDate: document.getElementById('businessDate').value,
      expiryOn: document.getElementById('expiryOn').value || null
    };
    await postJSON('/stock/entry', payload);
    toastr.success('Stock entry saved.');
  }

  document.getElementById('saveEntry').addEventListener('click', save);
  document.addEventListener('DOMContentLoaded', loadItems);
})();
</script>
}
