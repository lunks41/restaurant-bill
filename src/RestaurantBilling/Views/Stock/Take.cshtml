<div class="app-module-header">
    <h1 class="h3 mb-1">Stock</h1>
    <p class="app-muted mb-0">Inventory movements, losses, and physical stock checks.</p>
</div>
<nav class="nav app-module-tabs gap-2">
    <a class="nav-link" asp-controller="Stock" asp-action="Entry">Entry</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Adjustment">Adjustment</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Loss">Loss</a>
    <a class="nav-link active" asp-controller="Stock" asp-action="Take">Stock Take</a>
</nav>
<div class="app-surface">
    <div class="row g-2">
        <div class="col-md-4"><label class="form-label-custom">Item</label><select id="itemId" class="form-select-custom"></select></div>
        <div class="col-md-3"><label class="form-label-custom">Physical Qty</label><input id="physicalQty" type="number" step="0.001" class="form-control-custom" /></div>
        <div class="col-md-3"><label class="form-label-custom">Business Date</label><input id="businessDate" type="date" class="form-control-custom" /></div>
        <div class="col-md-2 d-flex align-items-end"><button id="runTake" class="btn-accent">Check Variance</button></div>
    </div>
    <div class="mt-3" id="takeResult"></div>
</div>

@section Scripts {
<script>
(() => {
  const today = new Date().toISOString().slice(0, 10);
  document.getElementById('businessDate').value = today;

  async function loadItems() {
    const rows = await getJSON('/stock/items?outletId=1');
    document.getElementById('itemId').innerHTML = rows.map(x => `<option value="${x.itemId}">${x.itemName}</option>`).join('');
  }

  async function run() {
    const result = await postJSON('/stock/take', {
      outletId: 1,
      itemId: parseInt(document.getElementById('itemId').value, 10),
      physicalQty: parseFloat(document.getElementById('physicalQty').value || '0'),
      businessDate: document.getElementById('businessDate').value
    });
    document.getElementById('takeResult').innerHTML =
      `<div class="alert-custom">Theoretical: <b>${result.theoreticalQty}</b>, Physical: <b>${result.physicalQty}</b>, Variance: <b>${result.varianceQty}</b></div>`;
  }

  document.getElementById('runTake').addEventListener('click', run);
  document.addEventListener('DOMContentLoaded', loadItems);
})();
</script>
}
