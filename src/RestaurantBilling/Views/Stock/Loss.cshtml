<div class="app-module-header">
    <h1 class="h3 mb-1">Stock</h1>
    <p class="app-muted mb-0">Inventory movements, losses, and physical stock checks.</p>
</div>
<nav class="nav app-module-tabs gap-2">
    <a class="nav-link" asp-controller="Stock" asp-action="Entry">Entry</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Adjustment">Adjustment</a>
    <a class="nav-link active" asp-controller="Stock" asp-action="Loss">Loss</a>
    <a class="nav-link" asp-controller="Stock" asp-action="Take">Stock Take</a>
</nav>
<div class="app-surface">
    <div class="row g-2">
        <div class="col-md-4"><label class="form-label-custom">Item</label><select id="itemId" class="form-select-custom"></select></div>
        <div class="col-md-2"><label class="form-label-custom">Qty</label><input id="qty" type="number" step="0.001" class="form-control-custom" /></div>
        <div class="col-md-2"><label class="form-label-custom">Rate</label><input id="rate" type="number" step="0.01" class="form-control-custom" /></div>
        <div class="col-md-4"><label class="form-label-custom">Reason</label><input id="reason" type="text" class="form-control-custom" /></div>
    </div>
    <div class="row g-2 mt-1">
        <div class="col-md-3"><label class="form-label-custom">Business Date</label><input id="businessDate" type="date" class="form-control-custom" /></div>
        <div class="col-md-3 d-flex align-items-end"><button id="saveLoss" class="btn-accent">Save Loss</button></div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const today = new Date().toISOString().slice(0, 10);
  document.getElementById('businessDate').value = today;

  async function loadItems() {
    const rows = await getJSON('/stock/items?outletId=1');
    document.getElementById('itemId').innerHTML = rows.map(x => `<option value="${x.itemId}">${x.itemName}</option>`).join('');
  }

  async function save() {
    await postJSON('/stock/loss', {
      outletId: 1,
      itemId: parseInt(document.getElementById('itemId').value, 10),
      qty: parseFloat(document.getElementById('qty').value || '0'),
      rate: parseFloat(document.getElementById('rate').value || '0'),
      businessDate: document.getElementById('businessDate').value,
      reason: document.getElementById('reason').value || 'Loss'
    });
    toastr.success('Stock loss recorded.');
  }

  document.getElementById('saveLoss').addEventListener('click', save);
  document.addEventListener('DOMContentLoaded', loadItems);
})();
</script>
}
