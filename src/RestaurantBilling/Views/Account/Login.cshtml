@model RestaurantBilling.Models.Identity.LoginViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Sign in";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var brandName = ViewData["BrandName"] as string ?? "RestoBill";
}

<div class="login-page">
    <div class="login-content">
        <div class="login-form-side">
            <a class="login-logo-link" href="/" title="@brandName">
                <span class="login-logo-mark"><i class="fas fa-utensils" aria-hidden="true"></i></span>
                <span class="login-logo-text">@brandName</span>
            </a>
            <p class="login-eyebrow">Made for Indian restaurants</p>
            <h1 class="login-hero-title">Manage billing, kitchen, stock and reports with ease.</h1>
            <p class="login-hero-sub d-none d-md-block">@brandName is built for Indian restaurants, cafes, cloud kitchens and quick-service outlets with GST-ready billing, KOT and day-close workflow.</p>
            <div class="login-cultural-tags d-none d-md-flex" aria-label="Cuisine highlights">
                <span class="login-cultural-tag"><i class="fas fa-pepper-hot"></i> Tandoor</span>
                <span class="login-cultural-tag"><i class="fas fa-mug-hot"></i> Chai Counter</span>
                <span class="login-cultural-tag"><i class="fas fa-motorcycle"></i> Delivery</span>
            </div>

            <div class="login-card card">
                <div class="card-body p-4 p-md-5">
                    <h2 class="h4 mb-1">Welcome to @brandName</h2>
                    <p class="text-secondary mb-4">Sign in with your username and password.</p>

                    <form asp-action="Login" method="post" novalidate>
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label">User name</label>
                            <input asp-for="UserName" class="form-control form-control-lg login-input" autocomplete="username" placeholder="Your username" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg login-input" autocomplete="current-password" placeholder="Your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                        </div>

                        <button type="submit" class="btn login-submit-btn btn-lg w-100">Sign in</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="login-art-side" aria-hidden="true">
            <!-- Rotating mandala background SVG -->
            <svg class="india-mandala-bg" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
                <!-- 8-petal outer lotus -->
                <g fill="rgba(249,115,22,0.11)" stroke="rgba(249,115,22,0.38)" stroke-width="1.5">
                    <ellipse cx="200" cy="88" rx="22" ry="56"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(45 200 200)"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(90 200 200)"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(135 200 200)"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(180 200 200)"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(225 200 200)"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(270 200 200)"/>
                    <ellipse cx="200" cy="88" rx="22" ry="56" transform="rotate(315 200 200)"/>
                </g>
                <!-- 12-petal inner lotus -->
                <g fill="rgba(250,204,21,0.07)" stroke="rgba(250,204,21,0.26)" stroke-width="1">
                    <ellipse cx="200" cy="130" rx="14" ry="36"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(30 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(60 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(90 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(120 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(150 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(180 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(210 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(240 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(270 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(300 200 200)"/>
                    <ellipse cx="200" cy="130" rx="14" ry="36" transform="rotate(330 200 200)"/>
                </g>
                <!-- Concentric decorative circles (chakra rings) -->
                <circle cx="200" cy="200" r="172" fill="none" stroke="rgba(249,115,22,0.13)" stroke-width="1" stroke-dasharray="10 15"/>
                <circle cx="200" cy="200" r="132" fill="none" stroke="rgba(249,115,22,0.11)" stroke-width="1" stroke-dasharray="7 11"/>
                <circle cx="200" cy="200" r="92"  fill="none" stroke="rgba(250,204,21,0.17)" stroke-width="1" stroke-dasharray="5 8"/>
                <circle cx="200" cy="200" r="56"  fill="none" stroke="rgba(249,115,22,0.2)"  stroke-width="1"/>
                <!-- Spoke lines -->
                <g stroke="rgba(249,115,22,0.11)" stroke-width="1">
                    <line x1="200" y1="28"  x2="200" y2="372"/>
                    <line x1="28"  y1="200" x2="372" y2="200"/>
                    <line x1="79"  y1="79"  x2="321" y2="321"/>
                    <line x1="321" y1="79"  x2="79"  y2="321"/>
                </g>
                <!-- Center chakra -->
                <circle cx="200" cy="200" r="13" fill="rgba(249,115,22,0.26)"/>
                <circle cx="200" cy="200" r="5.5" fill="rgba(250,204,21,0.72)"/>
            </svg>

            <!-- Rajasthani Haveli / Arch structure -->
            <div class="india-haveli">
                <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg">
                    <!-- Outer Rajasthani pointed arch -->
                    <path d="M 28 362 L 28 188 C 28 88 88 18 140 16 C 192 18 252 88 252 188 L 252 362"
                          fill="rgba(249,115,22,0.05)" stroke="rgba(249,115,22,0.65)" stroke-width="2.5" stroke-linejoin="round"/>
                    <!-- Inner arch detail -->
                    <path d="M 54 362 L 54 194 C 54 106 98 44 140 42 C 182 44 226 106 226 194 L 226 362"
                          fill="none" stroke="rgba(249,115,22,0.22)" stroke-width="1.5"/>
                    <!-- Trefoil arch top decoration -->
                    <path d="M 88 88 Q 104 58 120 76 Q 134 54 140 50 Q 146 54 160 76 Q 176 58 192 88"
                          fill="rgba(250,204,21,0.1)" stroke="rgba(250,204,21,0.52)" stroke-width="1.5"/>
                    <!-- Finial top -->
                    <line x1="140" y1="16" x2="140" y2="2" stroke="rgba(249,115,22,0.52)" stroke-width="2"/>
                    <circle cx="140" cy="8"   r="8"   fill="rgba(249,115,22,0.4)"  stroke="rgba(250,204,21,0.7)" stroke-width="1.5"/>
                    <circle cx="140" cy="8"   r="3.5" fill="rgba(250,204,21,0.85)"/>
                    <!-- Pillar base bands -->
                    <rect x="18"  y="152" width="18" height="7" rx="2" fill="rgba(249,115,22,0.32)"/>
                    <rect x="244" y="152" width="18" height="7" rx="2" fill="rgba(249,115,22,0.32)"/>
                    <!-- Jaali (lattice) patterns inside arch -->
                    <g fill="none" stroke="rgba(249,115,22,0.16)" stroke-width="1">
                        <path d="M 68 298 Q 140 256 212 298"/>
                        <path d="M 78 318 Q 140 274 202 318"/>
                        <path d="M 88 340 Q 140 292 192 340"/>
                    </g>
                    <!-- Hanging bells / ghunghru -->
                    <circle cx="54"  cy="208" r="5" fill="rgba(250,204,21,0.52)"/>
                    <circle cx="54"  cy="222" r="3" fill="rgba(249,115,22,0.68)"/>
                    <circle cx="226" cy="208" r="5" fill="rgba(250,204,21,0.52)"/>
                    <circle cx="226" cy="222" r="3" fill="rgba(249,115,22,0.68)"/>
                    <!-- Diya (oil lamp) bases -->
                    <ellipse cx="98"  cy="350" rx="12" ry="5" fill="rgba(249,115,22,0.2)"/>
                    <ellipse cx="140" cy="344" rx="14" ry="6" fill="rgba(249,115,22,0.3)"/>
                    <ellipse cx="182" cy="350" rx="12" ry="5" fill="rgba(249,115,22,0.2)"/>
                    <!-- Diya flames -->
                    <path d="M 94 344 Q 98 330 102 344"  fill="rgba(250,204,21,0.75)" stroke="none"/>
                    <path d="M 136 338 Q 140 322 144 338" fill="rgba(249,115,22,0.92)" stroke="none"/>
                    <path d="M 178 344 Q 182 330 186 344" fill="rgba(250,204,21,0.75)" stroke="none"/>
                </svg>
            </div>

            <!-- Floating Indian food & spice elements -->
            <div class="india-float float-naan"><i class="fas fa-bread-slice"></i></div>
            <div class="india-float float-chai"><i class="fas fa-mug-hot"></i></div>
            <div class="india-float float-bowl"><i class="fas fa-bowl-food"></i></div>
            <div class="india-float float-pepper"><i class="fas fa-pepper-hot"></i></div>
            <div class="india-float float-star1"><i class="fas fa-star"></i></div>
            <div class="india-float float-star2"><i class="fas fa-star"></i></div>
            <div class="india-float float-star3"><i class="fas fa-circle"></i></div>

            <!-- Footer tagline -->
            <div class="india-art-footer">
                <p class="india-art-tagline">Thali &middot; Tandoor &middot; Takeaway</p>
                <p class="india-art-sub d-none d-lg-block">Inspired by Indian hospitality, designed for modern service speed.</p>
            </div>
        </div>
    </div>
</div>
