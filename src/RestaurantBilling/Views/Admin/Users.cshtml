@{
    ViewData["Title"] = "Users";
}

<div class="app-surface mb-3 d-flex justify-content-end">
    <button type="button" class="btn-accent" id="openAddUser">
        <i class="fas fa-plus"></i> Add User
    </button>
</div>

<div class="card">
    <div class="card-body-custom">
        <table id="usersTable" class="table-custom">
            <thead>
                <tr>
                    <th>User Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="usersBody">
                <tr><td colspan="4" class="text-center text-muted">No users loaded.</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userModalTitle">Add User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input id="userId" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">User name</label>
                    <input id="userName" class="form-control" placeholder="User name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input id="userEmail" class="form-control" placeholder="Email (optional)" />
                </div>
                <div>
                    <label class="form-label">Password</label>
                    <input id="userPassword" class="form-control" placeholder="Leave blank to keep current password on edit" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveUser">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Status Change</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="userConfirmText">
                Change this user status?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmUserToggle">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const modalEl = document.getElementById('userModal');
  if (!modalEl || !window.bootstrap) return;
  const modal = new window.bootstrap.Modal(modalEl);
  const confirmModalEl = document.getElementById('userConfirmModal');
  const confirmModal = confirmModalEl ? new window.bootstrap.Modal(confirmModalEl) : null;
  const confirmBtn = document.getElementById('confirmUserToggle');
  const confirmText = document.getElementById('userConfirmText');
  const idEl = document.getElementById('userId');
  const nameEl = document.getElementById('userName');
  const emailEl = document.getElementById('userEmail');
  const passwordEl = document.getElementById('userPassword');
  const titleEl = document.getElementById('userModalTitle');
  const saveBtnEl = document.getElementById('saveUser');
  let pendingToggleId = null;
  let pendingToggleLabel = "change";

  const notifySafe = (message, type = 'info') => {
    if (typeof window.notify === 'function') {
      window.notify(message, type);
      return;
    }
    if (typeof toastr !== 'undefined' && typeof toastr[type] === 'function') {
      toastr[type](message);
    }
  };

  async function load() {
    const rows = await getJSON(`/admin/users-data?_=${Date.now()}`);
    if (window.jQuery && jQuery.fn.DataTable) {
      const table = jQuery('#usersTable');
      if (jQuery.fn.dataTable.isDataTable(table)) table.DataTable().destroy();
    }
    document.getElementById('usersBody').innerHTML = rows.length
      ? rows.map(x => {
          const isLocked = !!x.lockoutEnabled;
          const statusBadge = isLocked
            ? '<span class="badge-custom badge-muted">Locked</span>'
            : '<span class="badge-custom badge-success">Active</span>';
          const toggleLabel = isLocked ? 'Unlock' : 'Lock';
          const toggleClass = isLocked ? 'btn-outline-success' : 'btn-outline-danger';
          return `<tr>
            <td>${x.userName}</td>
            <td>${x.email || ''}</td>
            <td>${statusBadge}</td>
            <td>
              <button class="btn btn-sm btn-outline-primary me-1" data-edit="${x.id}" data-name="${x.userName}" data-email="${x.email || ''}">Edit</button>
              <button class="btn btn-sm ${toggleClass}" data-toggle="${x.id}" data-label="${toggleLabel}">${toggleLabel}</button>
            </td>
          </tr>`;
        }).join('')
      : '<tr><td colspan="4" class="text-center text-muted">No users loaded.</td></tr>';
    bindRowActions();
    if (window.jQuery && jQuery.fn.DataTable) {
      const table = jQuery('#usersTable');
      table.DataTable({ pageLength: 10, responsive: true });
    }
  }

  const openAdd = () => {
    idEl.value = '';
    nameEl.value = '';
    emailEl.value = '';
    passwordEl.value = 'Admin@123';
    titleEl.textContent = 'Add User';
    saveBtnEl.textContent = 'Add';
    modal.show();
  };

  const openEdit = (btn) => {
    idEl.value = btn.getAttribute('data-edit') || '';
    nameEl.value = btn.getAttribute('data-name') || '';
    emailEl.value = btn.getAttribute('data-email') || '';
    passwordEl.value = '';
    titleEl.textContent = 'Edit User';
    saveBtnEl.textContent = 'Update';
    modal.show();
  };

  async function save() {
    const userName = nameEl.value.trim();
    if (!userName) {
      notifySafe('User name is required', 'warning');
      return;
    }
    const id = idEl.value;
    const payload = {
      userName,
      email: emailEl.value.trim(),
      password: passwordEl.value.trim()
    };
    try {
      if (id) {
        await postJSON(`/admin/users-update/${id}`, payload);
        notifySafe('User updated', 'success');
      } else {
        await postJSON('/admin/users-create', payload);
        notifySafe('User created', 'success');
      }
      modal.hide();
      await load();
    } catch {
      notifySafe('Unable to save user right now', 'error');
    }
  }

  function bindRowActions() {
    document.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => openEdit(btn)));
    document.querySelectorAll('[data-toggle]').forEach(btn => btn.addEventListener('click', () => {
      pendingToggleId = btn.getAttribute('data-toggle');
      pendingToggleLabel = btn.getAttribute('data-label') || 'Change';
      if (confirmText) confirmText.textContent = `${pendingToggleLabel} this user?`;
      confirmModal?.show();
    }));
  }

  document.getElementById('openAddUser')?.addEventListener('click', openAdd);
  saveBtnEl.addEventListener('click', save);
  confirmBtn?.addEventListener('click', async () => {
    if (!pendingToggleId) return;
    try {
      await postJSON(`/admin/users-lock-toggle/${pendingToggleId}`, {});
      notifySafe(`User ${pendingToggleLabel.toLowerCase()}ed`, 'success');
      confirmModal?.hide();
      pendingToggleId = null;
      await load();
    } catch {
      notifySafe('Unable to update user status', 'error');
    }
  });

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', load);
  else load();
})();
</script>
}
