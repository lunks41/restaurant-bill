@{
    ViewData["Title"] = "Dine-In POS";
    var initialTableName = Context?.Request?.Query["table"].ToString();
    var tableLabel = string.IsNullOrWhiteSpace(initialTableName) ? "Table Name" : initialTableName;
}

<div id="posRoot" class="pos-layout pos-layout-modern">
    <section class="pos-items-panel">
        <div class="pos-search-bar">
            <div class="pos-search-wrap">
                <i class="fas fa-magnifying-glass"></i>
                <input id="posSearch" class="pos-search-input" placeholder="Search menu..." autocomplete="off" />
            </div>
            <span class="pos-items-count" id="posItemsCount"></span>
        </div>
        <div class="pos-cats-inline" id="posCategoryTabs"></div>
        <div class="pos-items-grid" id="posItems"></div>
    </section>

    <aside class="pos-cart">
        <div class="cart-header">
            <div class="cart-header-top">
                <div class="cart-header-icon"><i class="fas fa-receipt"></i></div>
                <div class="cart-header-info">
                    <div class="cart-header-row">
                        <div class="cart-header-title" id="cartHeaderTitle">Order #</div>
                        <button type="button" class="btn-ghost cart-table-btn" id="btnTable"><i
                                class="fas fa-chair"></i>
                            @tableLabel</button>
                    </div>
                    <div class="cart-order-meta" id="cartOrderMeta">OPEN · dine-in</div>
                </div>
            </div>

            <section class="cart-customer">
                <button type="button" class="cart-customer-toggle" id="btnCustomerToggle" aria-expanded="false"
                    aria-controls="customerCollapse">
                    <span>Customer info</span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="cart-customer-collapse" id="customerCollapse" hidden>
                    <div class="cart-customer-field">
                        <label for="customerName">Name</label>
                        <input id="customerName" type="text" class="form-control-custom"
                            placeholder="Walk-in / guest" />
                    </div>
                    <div class="cart-customer-field">
                        <label for="customerPhone">Phone</label>
                        <input id="customerPhone" type="text" class="form-control-custom" placeholder="Optional" />
                    </div>
                    <button type="button" class="btn-settle cart-customer-save" id="btnSaveCustomer">Save
                        customer</button>
                </div>
            </section>
        </div>

        <div class="cart-kot-hint" id="cartKotHint">
            <i class="fas fa-circle-exclamation"></i>
            <span>Kitchen item not sent yet - use Send KOT.</span>
        </div>


        <div class="cart-items" id="posCartItems"></div>
        <div class="cart-totals">
            <div class="cart-total-row"><span>Subtotal</span><span id="posSubTotal">&#8377;0.00</span></div>
            <div class="cart-total-row"><span id="posTaxLabel">Tax</span><span id="posTaxTotal">&#8377;0.00</span></div>
            <div class="cart-total-row cart-total-discount">
                <span>Discount</span>
                <button type="button" class="cart-discount-btn" id="btnEditDiscount">
                    <span id="posDiscountTotal">&#8377;0.00</span>
                </button>
            </div>
            <div class="cart-total-row grand"><span>Total</span><span class="grand-amt"
                    id="posGrandTotal">&#8377;0.00</span>
            </div>
        </div>
        <div class="cart-actions">
            <div class="kot-status-badge" id="posKotStatus">Pending KOT</div>
            <button class="btn-kot" id="btnKot"><i class="fas fa-paper-plane"></i> Send KOT</button>
            <button class="btn-kot" id="btnKotPrint"><i class="fas fa-print"></i> KOT Print</button>
            <button class="btn-settle" id="btnSettle"><i class="fas fa-indian-rupee-sign"></i> Bill / Pay</button>
        </div>
        <div class="cart-inline-link-row">
            <button class="btn-inline-neutral" id="btnCancelLines">Cancel line item(s)...</button>
            <button class="btn-inline-danger" id="btnHold"><i class="fas fa-xmark"></i> Cancel order</button>
        </div>
        <button class="btn-ghost w-100 mt-2" id="btnBackTables">
            <i class="fas fa-arrow-left"></i> Back to tables
        </button>
    </aside>
</div>

<button type="button" class="float-quick-btn" id="posQuickBtn" title="Refresh POS">
    <i class="fas fa-arrows-rotate"></i>
</button>

<!-- Settle Bill Modal -->
<div class="settle-modal-overlay" id="settleOverlay">
    <div class="settle-modal">
        <div class="settle-modal-head">
            <h3><i class="fas fa-indian-rupee-sign me-2"></i>Settle Bill</h3>
            <button class="settle-modal-close" id="settleClose">&times;</button>
        </div>
        <div class="settle-modal-body">
            <div class="settle-summary" id="settleSummary"></div>
            <div class="settle-pay-label">Select Payment Method</div>
            <div class="settle-pay-grid">
                <div class="settle-pay-btn active" data-method="Cash">
                    <i class="fas fa-money-bill-wave"></i><span>Cash</span>
                </div>
                <div class="settle-pay-btn" data-method="Card">
                    <i class="fas fa-credit-card"></i><span>Card</span>
                </div>
                <div class="settle-pay-btn" data-method="UPI">
                    <i class="fas fa-mobile-screen"></i><span>UPI</span>
                </div>
            </div>
            <div class="settle-split-row">
                <input type="checkbox" id="settlePartialSplit" />
                <label for="settlePartialSplit">Partially (Cash + selected mode)</label>
            </div>
            <div class="form-group-custom" id="settlePartialCashGroup" style="display:none;">
                <label class="form-label-custom">Cash Amount</label>
                <input type="number" id="settlePartialCashInput" class="form-control-custom" step="0.01" min="0"
                    placeholder="Enter cash amount" />
                <div class="app-muted mt-1" id="settlePartialRemaining">Remaining in selected mode: ₹0.00</div>
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Amount Received</label>
                <input type="number" id="settleAmtInput" class="form-control-custom" step="0.01" />
            </div>
            <div id="settleChangeRow"
                style="display:none; background:var(--success-bg); border-radius:var(--radius-sm); padding:10px 14px; font-size:13px; font-weight:600; color:var(--success); margin-top:8px;">
                <i class="fas fa-coins me-1"></i>Change: <span id="settleChangeDue">&#8377;0.00</span>
            </div>
        </div>
        <div class="settle-modal-foot">
            <button class="btn-settle-cancel" id="settleCancelBtn">Cancel</button>
            <button class="btn-settle-confirm" id="settleConfirmBtn">
                <i class="fas fa-check-circle"></i> Confirm &amp; Print
            </button>
        </div>
    </div>
</div>

<!-- Cancel Order Confirm Modal -->
<div class="modal fade modal-custom" id="cancelOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-circle-exclamation text-warning me-2"></i>Cancel current order?
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0 text-muted">This will cancel the current draft and free the selected table.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">No, keep it</button>
                <button type="button" class="btn btn-danger" id="confirmCancelOrderBtn">Yes, cancel order</button>
            </div>
        </div>
    </div>
</div>

<!-- Hidden print receipt -->
<div class="receipt-wrap" id="receiptWrap"></div>

<!-- Table Picker Panel -->
<div class="side-panel-overlay" id="tablePanelOverlay">
    <div class="side-panel side-panel-md">
        <div class="side-panel-head">
            <h3><i class="fas fa-chair me-2"></i>Select Table</h3>
            <button class="side-panel-close" id="tablePanelClose">&times;</button>
        </div>
        <div class="side-panel-body">
            <p class="text-muted small mb-3">Tap a free table to assign it to the current order. Occupied tables have an
                active held bill.</p>
            <div class="table-pick-grid" id="tableGrid">
                <div style="padding:24px;text-align:center;color:var(--text-muted);">Loading tables&hellip;</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pos.js" asp-append-version="true"></script>
}
