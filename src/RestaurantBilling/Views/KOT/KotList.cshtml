@{
    Layout = "_LayoutKds";
    ViewData["Title"] = "KOT List";
}

<div class="kds-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <div class="kds-title"><i class="fas fa-ticket" style="color:#a1a1aa;margin-right:8px;"></i>KOT List</div>
        <div style="display:flex;gap:8px;">
            <button onclick="setKotStatusFilter('all')" id="kotFilterAll" class="kds-filter-active" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;font-weight:600;cursor:pointer;">All</button>
            <button onclick="setKotStatusFilter('Pending')" id="kotFilterPending" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#F59E0B;font-size:12px;font-weight:600;cursor:pointer;">Pending</button>
            <button onclick="setKotStatusFilter('Preparing')" id="kotFilterPreparing" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#3B82F6;font-size:12px;font-weight:600;cursor:pointer;">Preparing</button>
            <button onclick="setKotStatusFilter('Ready')" id="kotFilterReady" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#10B981;font-size:12px;font-weight:600;cursor:pointer;">Ready</button>
        </div>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
        <select id="kotStationFilter" style="height:32px;padding:0 10px;border-radius:8px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;">
            <option value="all">All stations</option>
        </select>
        <div id="kotCount" style="font-size:12px;color:#8B949E;"></div>
        <button onclick="loadKots()" style="padding:6px 14px;border-radius:8px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;cursor:pointer;"><i class="fas fa-rotate"></i> Refresh</button>
        <a href="/kot/screen" target="_blank" style="padding:6px 12px;border-radius:8px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;text-decoration:none;"><i class="fas fa-display"></i> KDS Screen</a>
    </div>
</div>

<div class="kds-grid" id="kotGrid">
    <div class="kot-card">
        <div class="kot-card-head">
            <div class="kot-no-label" style="display:flex;align-items:center;gap:8px;"><i class="fas fa-spinner fa-spin"></i> Loading KOTs...</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function apiGet(url) {
  return fetch(url, { headers: { "X-Requested-With": "XMLHttpRequest" } })
    .then((r) => {
      if (!r.ok) throw new Error(`Request failed: ${r.status}`);
      return r.json();
    });
}

function apiPost(url, payload) {
  return fetch(url, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "X-Requested-With": "XMLHttpRequest",
      "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value || ""
    },
    body: JSON.stringify(payload)
  }).then((r) => {
    if (!r.ok) throw new Error(`Request failed: ${r.status}`);
    return r.json();
  });
}

let allKots = [];
let activeFilter = "all";
let activeStation = "all";

window.setKotStatusFilter = function(status) {
  activeFilter = status;
  document.querySelectorAll('[id^="kotFilter"]').forEach(b => b.classList.remove("kds-filter-active"));
  const map = {
    all: "kotFilterAll",
    Pending: "kotFilterPending",
    Preparing: "kotFilterPreparing",
    Ready: "kotFilterReady"
  };
  document.getElementById(map[status])?.classList.add("kds-filter-active");
  renderKotGrid();
};

async function loadKots() {
  try {
    allKots = await apiGet("/kot/kots-data?outletId=1") || [];
    syncStationFilter();
    renderKotGrid();
  } catch {
    const grid = document.getElementById("kotGrid");
    if (grid) grid.innerHTML = `<div class="kot-card"><div class="kot-card-head"><div class="kot-no-label" style="color:#EF4444;"><i class="fas fa-exclamation-triangle"></i> Failed to load</div></div></div>`;
  }
}

function syncStationFilter() {
  const select = document.getElementById("kotStationFilter");
  if (!select) return;
  const prev = activeStation;
  const stationIds = Array.from(new Set(allKots
    .map(x => Number(x.kitchenStationId))
    .filter(x => Number.isFinite(x) && x > 0)))
    .sort((a, b) => a - b);
  select.innerHTML = `<option value="all">All stations</option>${stationIds.map(id => `<option value="${id}">Station ${id}</option>`).join("")}`;
  if (prev === "all" || stationIds.includes(Number(prev))) {
    select.value = prev;
  } else {
    activeStation = "all";
    select.value = "all";
  }
}

function renderKotGrid() {
  const grid = document.getElementById("kotGrid");
  if (!grid) return;

  const filtered = allKots.filter(x => {
    const statusOk = activeFilter === "all" || x.status === activeFilter;
    const stationOk = activeStation === "all" || String(x.kitchenStationId) === activeStation;
    return statusOk && stationOk;
  });

  const count = document.getElementById("kotCount");
  if (count) count.textContent = `${filtered.length} order${filtered.length !== 1 ? "s" : ""}`;

  if (!filtered.length) {
    grid.innerHTML = `<div class="kot-card" style="grid-column:1/-1;"><div class="kot-card-head" style="justify-content:center;padding:32px;"><div style="text-align:center;color:#8B949E;"><i class="fas fa-check-circle" style="font-size:40px;color:#10B981;display:block;margin-bottom:12px;"></i><div style="font-size:16px;font-weight:700;color:#E6EDF3;">All Clear!</div><div style="font-size:13px;margin-top:4px;">No matching KOTs</div></div></div></div>`;
    return;
  }

  grid.innerHTML = filtered.map(kot => {
    const elapsed = kot.kotDateIso ? Math.floor((Date.now() - new Date(kot.kotDateIso).getTime()) / 60000) : null;
    const timerClass = elapsed > 20 ? "urgent" : elapsed > 10 ? "warn" : "ok";
    const stationLabel = kot.kitchenStationId ? `Station ${kot.kitchenStationId}` : "Station -";
    const itemsHtml = (kot.items || []).map(i => `
      <div class="kot-line">
        <div class="kot-qty-badge">${i.qty}</div>
        <div class="kot-item-nm">${i.itemName}</div>
      </div>`).join("") || `<div style="padding:8px 0;color:#8B949E;font-size:12px;">No item details</div>`;
    const nextStatus = kot.status === "Pending" ? "Preparing" : kot.status === "Preparing" ? "Ready" : kot.status === "Ready" ? "Served" : null;

    return `
      <div class="kot-card ${elapsed > 20 ? "alert-urgent" : ""}">
        <div class="kot-card-head">
          <div>
            <div class="kot-no-label">${kot.kotNo}</div>
            ${kot.kotEventType === "AddOn" ? `<div class="kot-event-badge">Additional KOT</div>` : ''}
            <div class="kot-table-label"><i class="fas fa-kitchen-set"></i> ${stationLabel}</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
            <div class="kot-timer ${timerClass}">${elapsed != null && elapsed >= 0 ? `${elapsed}m` : "—"}</div>
            <div style="font-size:10px;font-weight:700;color:#8B949E;">${kot.status}</div>
          </div>
        </div>
        <div class="kot-items-list">${itemsHtml}</div>
        <div class="kot-actions">
          ${nextStatus ? `<button class="btn-kds ${nextStatus === "Preparing" ? "start" : nextStatus === "Ready" ? "ready" : "served"}" onclick="kotAdvance(${kot.kotHeaderId},'${nextStatus}')">${nextStatus}</button>` : ""}
          ${(kot.status === "Pending" || kot.status === "Preparing") ? `<button class="btn-kds" style="background:#1F2937;color:#9CA3AF;" onclick="kotAdvance(${kot.kotHeaderId},'Cancelled')">Cancel</button>` : ""}
        </div>
      </div>`;
  }).join("");
}

window.kotAdvance = async function(id, status) {
  try {
    await apiPost("/kot/status", { outletId: 1, kotId: id, status });
    if (typeof toastr !== "undefined") toastr.success(`KOT marked ${status}`);
    await loadKots();
  } catch {
    if (typeof toastr !== "undefined") toastr.error("Update failed");
  }
};

document.addEventListener("DOMContentLoaded", () => {
  document.getElementById("kotStationFilter")?.addEventListener("change", (e) => {
    activeStation = e.target.value;
    renderKotGrid();
  });
  loadKots();
  setInterval(loadKots, 30000);
});
</script>
<style>
.kds-filter-active {
  background: #fafafa !important;
  border-color: #fafafa !important;
  color: #18181b !important;
}
</style>
}
