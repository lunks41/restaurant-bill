@{
    Layout = "_LayoutKds";
    ViewData["Title"] = "KDS Screen";
    ViewBag.UseSignalR = true;
    var uiStamp = DateTime.UtcNow.ToString("yyyyMMddHHmmss");
}

<div class="kds-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <div class="kds-title"><i class="fas fa-display" style="color:#a1a1aa;margin-right:8px;"></i>Kitchen Display <span style="font-size:10px;color:#8B949E;font-weight:600;">UI @uiStamp</span></div>
        <div style="display:flex;gap:8px;">
            <button onclick="kdsFilter('all')" id="kdsFilterAll" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;font-weight:600;cursor:pointer;" class="kds-filter-active">All</button>
            <button onclick="kdsFilter('Pending')" id="kdsFilterPending" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#F59E0B;font-size:12px;font-weight:600;cursor:pointer;">Pending</button>
            <button onclick="kdsFilter('Preparing')" id="kdsFilterPrep" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#3B82F6;font-size:12px;font-weight:600;cursor:pointer;">Preparing</button>
            <button onclick="kdsFilter('Served')" id="kdsFilterServed" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#A78BFA;font-size:12px;font-weight:600;cursor:pointer;">Served</button>
        </div>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
        <div id="kdsCount" style="font-size:12px;color:#8B949E;"></div>
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:#E6EDF3;cursor:pointer;">
            <input type="checkbox" id="kdsAudioToggle" checked />
            Audio alert
        </label>
        <button onclick="kdsLoadKots()" style="padding:6px 14px;border-radius:8px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;cursor:pointer;"><i class="fas fa-rotate"></i> Refresh</button>
        <div id="kdsClock" class="kds-clock"></div>
    </div>
</div>

<div class="kds-grid" id="kdsGrid">
    <div class="kot-card">
        <div class="kot-card-head">
            <div class="kot-no-label" style="display:flex;align-items:center;gap:8px;"><i class="fas fa-spinner fa-spin"></i> Loading KOTs...</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function apiGet(url) {
  return fetch(url, { headers: { "X-Requested-With": "XMLHttpRequest" } })
    .then((r) => {
      if (!r.ok) throw new Error(`Request failed: ${r.status}`);
      return r.json();
    });
}

function apiPost(url, payload) {
  return fetch(url, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "X-Requested-With": "XMLHttpRequest",
      "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value || ""
    },
    body: JSON.stringify(payload)
  }).then((r) => {
    if (!r.ok) throw new Error(`Request failed: ${r.status}`);
    return r.json();
  });
}

let allKots = [];
let activeFilter = 'all';
let seenKotIds = new Set();
let isFirstKdsLoad = true;
const KDS_AUDIO_PREF_KEY = "kds.audio.enabled";
const statusPriority = ["Pending", "Preparing", "Served", "Cancelled"];

function normalizeStatus(status) {
  if (!status) return "Pending";
  if (status === "Pending") return "Pending";
  if (status === "Preparing") return "Preparing";
  if (status === "Served") return "Served";
  if (status === "Cancelled") return "Cancelled";
  return "Pending";
}

function deriveCardStatus(kot) {
  const itemStatuses = (kot.items || []).map(i => normalizeStatus(i.status || kot.status));
  if (!itemStatuses.length) return normalizeStatus(kot.status);
  if (itemStatuses.includes("Pending")) return "Pending";
  if (itemStatuses.includes("Preparing")) return "Preparing";
  if (itemStatuses.every(s => s === "Served" || s === "Cancelled")) {
    return itemStatuses.includes("Served") ? "Served" : "Cancelled";
  }
  if (itemStatuses.every(s => s === "Served")) return "Served";
  if (itemStatuses.every(s => s === "Cancelled")) return "Cancelled";
  return normalizeStatus(kot.status);
}

window.kdsFilter = function(f) {
  activeFilter = f;
  document.querySelectorAll('[id^="kdsFilter"]').forEach(b => b.classList.remove('kds-filter-active'));
  const map = {all:'kdsFilterAll', Pending:'kdsFilterPending', Preparing:'kdsFilterPrep', Served:'kdsFilterServed'};
  document.getElementById(map[f])?.classList.add('kds-filter-active');
  renderKdsGrid(allKots);
};

function renderKdsGrid(rows) {
  const grid = document.getElementById("kdsGrid");
  if (!grid) return;
  const filtered = activeFilter === 'all' ? rows : rows.filter(r => deriveCardStatus(r) === activeFilter);
  const cnt = document.getElementById("kdsCount");
  if (cnt) cnt.textContent = `${filtered.length} order${filtered.length !== 1 ? 's' : ''}`;

  if (!filtered.length) {
    grid.innerHTML = `<div class="kot-card" style="grid-column:1/-1;"><div class="kot-card-head" style="justify-content:center;padding:32px;"><div style="text-align:center;color:#8B949E;"><i class="fas fa-check-circle" style="font-size:40px;color:#10B981;display:block;margin-bottom:12px;"></i><div style="font-size:16px;font-weight:700;color:#E6EDF3;">All Clear!</div><div style="font-size:13px;margin-top:4px;">No active KOTs</div></div></div></div>`;
    return;
  }

  grid.innerHTML = filtered.map(r => {
    const effectiveStatus = deriveCardStatus(r);
    const statusColor = { Pending:'#F59E0B', Preparing:'#3B82F6', Served:'#6B7280', Cancelled:'#EF4444' }[effectiveStatus] || '#8B949E';
    const timerClass = r.elapsedMin > 15 ? 'urgent' : r.elapsedMin > 8 ? 'warn' : 'ok';
    const itemsHtml  = (r.items || []).map(i => `<div class="kot-line"><div class="kot-item-nm"><span class="kot-item-qty">${i.qty}</span><span class="kot-item-name">${i.itemName}</span><span class="kot-item-status">${normalizeStatus(i.status || effectiveStatus)}</span></div></div>`).join('') || `<div style="padding:8px 0;color:#8B949E;font-size:12px;">No item details</div>`;
    return `
      <div class="kot-card ${r.elapsedMin > 15 ? 'alert-urgent' : ''}">
        <div class="kot-card-head">
          <div>
            <div class="kot-no-label">${r.kotNo}</div>
            ${r.kotEventType === "AddOn" ? `<div class="kot-event-badge">Additional KOT</div>` : ''}
            ${r.billNo ? `<div class="kot-table-label"><i class="fas fa-receipt" style="font-size:10px;"></i> Order: ${r.billNo}</div>` : ''}
            ${r.tableName ? `<div class="kot-table-label"><i class="fas fa-chair" style="font-size:10px;"></i> Table: ${r.tableName}</div>` : ''}
            ${!r.tableName ? `<div class="kot-table-label"><i class="fas fa-chair" style="font-size:10px;"></i> Table: -</div>` : ''}
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
            <div class="kot-timer ${timerClass}">${r.elapsedMin != null ? r.elapsedMin+'m' : r.kotDate}</div>
            <div style="font-size:10px;font-weight:700;color:${statusColor};">${effectiveStatus}</div>
          </div>
        </div>
        <div class="kot-items-list">${itemsHtml}</div>
        <div class="kot-actions">
          ${effectiveStatus === 'Pending'   ? `<button class="btn-kds start"  onclick="kdsUpdate(${r.kotHeaderId},'Preparing')"><i class="fas fa-fire"></i> Preparing</button>` : ''}
          ${effectiveStatus === 'Preparing' ? `<button class="btn-kds served" onclick="kdsUpdate(${r.kotHeaderId},'Served')"><i class="fas fa-check"></i> Served</button>` : ''}
          ${effectiveStatus === 'Pending' || effectiveStatus === 'Preparing' ? `<button class="btn-kds" style="background:#1F2937;color:#9CA3AF;" onclick="kdsUpdate(${r.kotHeaderId},'Cancelled')">Cancel</button>` : ''}
        </div>
      </div>`;
  }).join('');
}

window.kdsUpdate = async function(kotId, status) {
  try {
    await apiPost('/kot/status', { outletId: 1, kotId, status });
    if (typeof toastr !== 'undefined') toastr.success(`KOT ${status}`);
    await kdsLoadKots();
  } catch { if (typeof toastr !== 'undefined') toastr.error('Update failed'); }
};

window.kdsLoadKots = async function() {
  try {
    const rows = await apiGet('/kot/kots-data?outletId=1');
    maybePlayNewKotAlert(rows || []);
    allKots = (rows || []).map(r => ({
      ...r,
      elapsedMin: r.kotDate ? Math.floor((Date.now() - new Date(r.kotDate).getTime()) / 60000) : null
    }));
    renderKdsGrid(allKots);
  } catch (e) {
    const grid = document.getElementById("kdsGrid");
    if (grid) grid.innerHTML = `<div class="kot-card"><div class="kot-card-head"><div class="kot-no-label" style="color:#EF4444;"><i class="fas fa-exclamation-triangle"></i> Failed to load</div></div></div>`;
  }
};

function maybePlayNewKotAlert(rows) {
  const incomingIds = rows
    .map(r => Number(r.kotHeaderId))
    .filter(id => Number.isFinite(id) && id > 0);
  if (isFirstKdsLoad) {
    incomingIds.forEach(id => seenKotIds.add(id));
    isFirstKdsLoad = false;
    return;
  }
  const hasNewKot = incomingIds.some(id => !seenKotIds.has(id));
  incomingIds.forEach(id => seenKotIds.add(id));
  if (hasNewKot && isKdsAudioEnabled()) {
    playKdsBeep();
  }
}

function isKdsAudioEnabled() {
  const toggle = document.getElementById("kdsAudioToggle");
  return toggle ? toggle.checked : true;
}

function playKdsBeep() {
  try {
    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
    const osc = audioContext.createOscillator();
    const gain = audioContext.createGain();
    osc.type = "sine";
    osc.frequency.setValueAtTime(880, audioContext.currentTime);
    gain.gain.setValueAtTime(0.0001, audioContext.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.2, audioContext.currentTime + 0.02);
    gain.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.18);
    osc.connect(gain);
    gain.connect(audioContext.destination);
    osc.start();
    osc.stop(audioContext.currentTime + 0.2);
  } catch {
    // Ignore audio playback errors (browser policy/user settings).
  }
}

document.addEventListener("DOMContentLoaded", () => {
  const audioToggle = document.getElementById("kdsAudioToggle");
  if (audioToggle) {
    const saved = localStorage.getItem(KDS_AUDIO_PREF_KEY);
    audioToggle.checked = saved !== "0";
    audioToggle.addEventListener("change", () => {
      localStorage.setItem(KDS_AUDIO_PREF_KEY, audioToggle.checked ? "1" : "0");
    });
  }
  kdsLoadKots();
  setInterval(kdsLoadKots, 30000);
});
</script>
<style>
.kds-filter-active {
  background: #fafafa !important;
  border-color: #fafafa !important;
  color: #18181b !important;
}
.kot-card {
  display: flex;
  flex-direction: column;
}
.kot-items-list {
  max-height: 260px;
  overflow-y: auto;
}
.kot-actions {
  margin-top: auto;
}
.kot-item-qty {
  display: inline-block;
  min-width: 22px;
  padding: 1px 6px;
  border-radius: 999px;
  background: #1f2937;
  color: #cbd5e1;
  margin-right: 6px;
  font-size: 11px;
}
.kot-item-name {
  color: #e5e7eb;
  margin-right: 8px;
}
.kot-item-status {
  display: inline-block;
  padding: 1px 7px;
  border-radius: 999px;
  background: #111827;
  color: #93c5fd;
  border: 1px solid #1d4ed8;
  font-size: 11px;
}
</style>
}
