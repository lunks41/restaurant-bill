@{
    Layout = "_LayoutKds";
    ViewData["Title"] = "KDS Screen";
    ViewBag.UseSignalR = true;
}

<div class="kds-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <div class="kds-title"><i class="fas fa-display" style="color:#FF6B35;margin-right:8px;"></i>Kitchen Display</div>
        <div style="display:flex;gap:8px;">
            <button onclick="kdsFilter('all')" id="kdsFilterAll" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;font-weight:600;cursor:pointer;" class="kds-filter-active">All</button>
            <button onclick="kdsFilter('Pending')" id="kdsFilterPending" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#F59E0B;font-size:12px;font-weight:600;cursor:pointer;">Pending</button>
            <button onclick="kdsFilter('Preparing')" id="kdsFilterPrep" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#3B82F6;font-size:12px;font-weight:600;cursor:pointer;">Preparing</button>
            <button onclick="kdsFilter('Ready')" id="kdsFilterReady" style="padding:5px 14px;border-radius:20px;border:1px solid #30363D;background:#21262D;color:#10B981;font-size:12px;font-weight:600;cursor:pointer;">Ready</button>
        </div>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
        <div id="kdsCount" style="font-size:12px;color:#8B949E;"></div>
        <button onclick="kdsLoadKots()" style="padding:6px 14px;border-radius:8px;border:1px solid #30363D;background:#21262D;color:#E6EDF3;font-size:12px;cursor:pointer;"><i class="fas fa-rotate"></i> Refresh</button>
        <div id="kdsClock" class="kds-clock"></div>
    </div>
</div>

<div class="kds-grid" id="kdsGrid">
    <div class="kot-card">
        <div class="kot-card-head">
            <div class="kot-no-label" style="display:flex;align-items:center;gap:8px;"><i class="fas fa-spinner fa-spin"></i> Loading KOTs...</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let allKots = [];
let activeFilter = 'all';

window.kdsFilter = function(f) {
  activeFilter = f;
  document.querySelectorAll('[id^="kdsFilter"]').forEach(b => b.classList.remove('kds-filter-active'));
  const map = {all:'kdsFilterAll', Pending:'kdsFilterPending', Preparing:'kdsFilterPrep', Ready:'kdsFilterReady'};
  document.getElementById(map[f])?.classList.add('kds-filter-active');
  renderKdsGrid(allKots);
};

function renderKdsGrid(rows) {
  const grid = document.getElementById("kdsGrid");
  if (!grid) return;
  const filtered = activeFilter === 'all' ? rows : rows.filter(r => r.status === activeFilter);
  const cnt = document.getElementById("kdsCount");
  if (cnt) cnt.textContent = `${filtered.length} order${filtered.length !== 1 ? 's' : ''}`;

  if (!filtered.length) {
    grid.innerHTML = `<div class="kot-card" style="grid-column:1/-1;"><div class="kot-card-head" style="justify-content:center;padding:32px;"><div style="text-align:center;color:#8B949E;"><i class="fas fa-check-circle" style="font-size:40px;color:#10B981;display:block;margin-bottom:12px;"></i><div style="font-size:16px;font-weight:700;color:#E6EDF3;">All Clear!</div><div style="font-size:13px;margin-top:4px;">No active KOTs</div></div></div></div>`;
    return;
  }

  grid.innerHTML = filtered.map(r => {
    const statusColor = { Pending:'#F59E0B', Preparing:'#3B82F6', Ready:'#10B981', Served:'#6B7280', Cancelled:'#EF4444' }[r.status] || '#8B949E';
    const timerClass = r.elapsedMin > 15 ? 'urgent' : r.elapsedMin > 8 ? 'warn' : 'ok';
    const itemsHtml  = (r.items || []).map(i => `<div class="kot-line"><div class="kot-qty-badge">${i.qty}</div><div class="kot-item-nm">${i.itemName}</div></div>`).join('') || `<div style="padding:8px 0;color:#8B949E;font-size:12px;">No item details</div>`;
    return `
      <div class="kot-card ${r.elapsedMin > 15 ? 'alert-urgent' : ''}">
        <div class="kot-card-head">
          <div>
            <div class="kot-no-label">${r.kotNo}</div>
            ${r.tableName ? `<div class="kot-table-label"><i class="fas fa-chair" style="font-size:10px;"></i> ${r.tableName}</div>` : ''}
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
            <div class="kot-timer ${timerClass}">${r.elapsedMin != null ? r.elapsedMin+'m' : r.kotDate}</div>
            <div style="font-size:10px;font-weight:700;color:${statusColor};">${r.status}</div>
          </div>
        </div>
        <div class="kot-items-list">${itemsHtml}</div>
        <div class="kot-actions">
          ${r.status === 'Pending'   ? `<button class="btn-kds start"  onclick="kdsUpdate(${r.kotHeaderId},'Preparing')"><i class="fas fa-fire"></i> Start</button>` : ''}
          ${r.status === 'Preparing' ? `<button class="btn-kds ready"  onclick="kdsUpdate(${r.kotHeaderId},'Ready')"><i class="fas fa-bell"></i> Ready</button>` : ''}
          ${r.status === 'Ready'     ? `<button class="btn-kds served" onclick="kdsUpdate(${r.kotHeaderId},'Served')"><i class="fas fa-check"></i> Served</button>` : ''}
          ${r.status === 'Pending' || r.status === 'Preparing' ? `<button class="btn-kds" style="background:#1F2937;color:#9CA3AF;" onclick="kdsUpdate(${r.kotHeaderId},'Cancelled')">Cancel</button>` : ''}
        </div>
      </div>`;
  }).join('');
}

window.kdsUpdate = async function(kotId, status) {
  try {
    await postJSON('/kitchen/status', { outletId: 1, kotId, status });
    if (typeof toastr !== 'undefined') toastr.success(`KOT ${status}`);
    await kdsLoadKots();
  } catch { if (typeof toastr !== 'undefined') toastr.error('Update failed'); }
};

window.kdsLoadKots = async function() {
  try {
    const rows = await getJSON('/kitchen/kots-data?outletId=1');
    allKots = (rows || []).map(r => ({
      ...r,
      elapsedMin: r.kotDate ? Math.floor((Date.now() - new Date(r.kotDate).getTime()) / 60000) : null
    }));
    renderKdsGrid(allKots);
  } catch (e) {
    const grid = document.getElementById("kdsGrid");
    if (grid) grid.innerHTML = `<div class="kot-card"><div class="kot-card-head"><div class="kot-no-label" style="color:#EF4444;"><i class="fas fa-exclamation-triangle"></i> Failed to load</div></div></div>`;
  }
};

document.addEventListener("DOMContentLoaded", () => {
  kdsLoadKots();
  setInterval(kdsLoadKots, 30000);
});
</script>
<style>
.kds-filter-active { background: #FF6B35 !important; border-color: #FF6B35 !important; color: white !important; }
</style>
}
